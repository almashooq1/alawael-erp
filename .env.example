# CCTV_FACE_MATCH_THRESHOLD=0.72                 # cosine similarity
# CCTV_LOITER_WINDOW_MS=300000                   # loitering window
# CCTV_LOITER_THRESHOLD=6                        # events to trigger
# CCTV_DEFAULT_ROOM_MAX=25                       # default room occupancy
# CCTV_DISABLE_SCHEDULERS=0                      # 1 to disable schedulers

