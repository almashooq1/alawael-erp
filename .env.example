# HIKVISION_BREAKER_COOLDOWN_MS=60000            # circuit cooldown
# CCTV_PROBE_BATCH=20                            # cameras per health tick
# CCTV_FAIL_THRESHOLD=3                          # offline after N failures
# CCTV_HEALTH_TICK_MS=60000                      # camera probe cadence
# CCTV_NVR_TICK_MS=300000                        # NVR probe cadence
# CCTV_REAP_TICK_MS=30000                        # idle stream reaper
# CCTV_STREAM_IDLE_MS=30000                      # stream session idle
# CCTV_MAX_SESSIONS_PER_USER=6                   # concurrency cap
