# ═══════════════════════════════════════════════════════════════════════════════
# Al-Awael ERP — Docker Compose Environment Variables
# Copy to .env and set real values before running docker compose up
# ═══════════════════════════════════════════════════════════════════════════════

# ─── REQUIRED SECRETS (no defaults — compose will fail if unset) ─────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=          # ← set a strong password
REDIS_PASSWORD=               # ← set a strong password
JWT_SECRET=                   # ← generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── Ports ───────────────────────────────────────────────────────────────────
MONGO_PORT=27017
REDIS_PORT=6379
BACKEND_PORT=3001
FRONTEND_PORT=3004
GATEWAY_PORT=8080
# WHATSAPP_PORT=3010  # ARCHIVED — whatsapp service removed
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ─── Frontend ────────────────────────────────────────────────────────────────
# عنوان API الذي يستخدمه الـ React — يُحدَّد وقت البناء (build time)
REACT_APP_API_URL=http://localhost:8080/api

# ─── CORS & Network Access ───────────────────────────────────────────────────
# ⚠️ مهم: إذا أردت الوصول للموقع من كمبيوتر آخر أو شبكة مختلفة:
#
# 1) اعرف IP الخادم (Server IP):
#    - على Linux/Mac: ip addr show  أو  hostname -I
#    - على Windows:  ipconfig
#
# 2) أضف IP الخادم لمتغير CORS_ORIGINS في ملف .env:
#    CORS_ORIGINS=http://192.168.1.100,http://localhost:3004,https://alawael.org
#
# 3) أضف عنوان الـ Frontend URL:
#    FRONTEND_URL=http://192.168.1.100
#
# مثال لبيئة الإنتاج مع domain:
# CORS_ORIGINS=https://alawael.org,https://www.alawael.org
# FRONTEND_URL=https://alawael.org
#
# مثال للوصول من الشبكة المحلية (LAN):
# CORS_ORIGINS=http://192.168.1.100,http://localhost:3004,http://localhost:8080
# FRONTEND_URL=http://192.168.1.100

CORS_ORIGINS=http://localhost:3004,http://localhost:3000,http://localhost:8080
# FRONTEND_URL=

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_EXPIRE=7d
# ─── Missing Variables (added by Environment_Fixer) ────────────
METRICS_TOKEN=                   # Bearer token for /metrics endpoint
SESSION_SECRET=                  # Session cookie signing secret (min 16 chars)
TZ=Asia/Riyadh                   # Timezone for all containers
BUILD_TIME=                      # Build timestamp (set during CI/CD)
GIT_SHA=                         # Git commit SHA (set during CI/CD)

