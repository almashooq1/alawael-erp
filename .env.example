# ─── Blockchain Certificates — شهادات البلوكتشين ───────────────────────────
# Adapter selection. Real chains plug in by adding a new adapter file.
# BLOCKCHAIN_NETWORK=internal                   # internal | mock-ethereum | mock-polygon | ethereum | polygon | sepolia | amoy
# BLOCKCHAIN_BATCH_SIZE=100                      # max leaves per anchor batch (advisory)
# BLOCKCHAIN_VERIFY_PUBLIC_BASE=https://alaweal.org/verify   # QR target; falls back to API path
# BLOCKCHAIN_CONTRACT_ADDRESS=                   # for mock-* adapters; auto-derived if blank
# BLOCKCHAIN_PDF_ORG_NAME_AR=مراكز الأوائل للرعاية النهارية
# BLOCKCHAIN_PDF_ORG_NAME_EN=Al-Awael Day Care Centers
# BLOCKCHAIN_PDF_FONT_AR=                        # absolute path to .ttf for Arabic glyphs

# Real-chain anchoring (only when BLOCKCHAIN_NETWORK is ethereum/polygon/sepolia/amoy).
# Requires `npm install ethers@^6` in backend/.
# BLOCKCHAIN_ETH_RPC_URL=                        # e.g. https://polygon-rpc.example
# BLOCKCHAIN_ETH_PRIVATE_KEY=                    # hot signer; rotate quarterly

# Auto-issue feature flag — when "1", LMS / IEP / onboarding completion
# events trigger certificate issuance automatically (via change streams).
# BLOCKCHAIN_AUTO_ISSUE=0                        # 0 (off) | 1 (on)

