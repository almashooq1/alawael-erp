# ─── Audit Service (خدمة التدقيق) ───────────────────────────────────────────
AUDIT_SERVICE_PORT=3230

# ─── Search Service (خدمة البحث — requires Elasticsearch profile) ───────────
SEARCH_SERVICE_PORT=3240

# ─── Webhook Worker (خدمة الويب هوك) ────────────────────────────────────────
WEBHOOK_WORKER_PORT=3250
WEBHOOK_MAX_RETRIES=5
WEBHOOK_TIMEOUT_MS=10000

# ─── Scheduler (خدمة الجدولة) ───────────────────────────────────────────────
SCHEDULER_PORT=3260

# ─── File Processor (خدمة معالجة الملفات) ───────────────────────────────────
FILE_PROCESSOR_PORT=3270
MAX_FILE_SIZE=52428800
# WATERMARK_TEXT=نظام الأوائل

# ─── Saudi Gov Gateway (بوابة الخدمات الحكومية السعودية) ─────────────────────
SAUDI_GOV_PORT=3280
# GOV_ENCRYPTION_KEY=           # ← generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# GOSI_API_URL=https://api.gosi.gov.sa/v1
# QIWA_API_URL=https://api.qiwa.sa/v1
# TAQAT_API_URL=https://api.taqat.sa/v1
# MUDAD_API_URL=https://api.mudad.com.sa/v1
# NOOR_API_URL=https://api.noor.moe.gov.sa/v1
# MOI_API_URL=https://api.moi.gov.sa/v1
# MUQEEM_API_URL=https://api.muqeem.sa/v1

# ─── IoT Gateway (بوابة إنترنت الأشياء) ────────────────────────────────────
IOT_GATEWAY_PORT=3290

