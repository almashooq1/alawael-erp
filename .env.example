# ══════════════════════════════════════════════════════════════════════════════
# Operational hardening (added 2026-05-02)
# Each block ships OFF by default — flip on at go-live, see
# docs/blueprint/23-go-live-checklist.md
# ══════════════════════════════════════════════════════════════════════════════

# ─── Backups & disaster recovery ────────────────────────────────────────────
# AES-256-GCM encryption at rest. Generate with:
#   node backend/scripts/backup-keygen.js
# Lose this key = lose access to every encrypted archive. Escrow it.
BACKUP_ENCRYPTION_KEY=
# Minimum row counts that signal a healthy DR drill restore.
DR_MIN_USERS=1
DR_MIN_BENEFICIARIES=0
# Per-step timeout for the DR verification (default 10 min).
DR_VERIFY_TIMEOUT_MS=600000

# ─── Ops-alerter (whatsapp/sms/email fan-out for production incidents) ──────
# Comma-separated. Recipients hit the unifiedNotifier fallback chain.
# Required for: backup failures, DR drill failures, ZATCA REJECTED, ZATCA
# 24h SLA breaches, post-deploy smoke failures.
OPS_ALERT_EMAIL=
OPS_ALERT_PHONE=
# Optional: override the auto-channel pick. Leave blank for default chain.
OPS_ALERT_CHANNELS=

# ─── ZATCA Phase 2 (auto-submission + 24h SLA enforcement) ───────────────────
# Off by default — flip on at go-live AFTER per-branch onboarding via
# the /zatca-credentials admin page.
ZATCA_AUTOSUBMIT=false
ZATCA_SLA_SWEEPER_ENABLED=false
ZATCA_SLA_INTERVAL_MS=1800000      # tick every 30 min
ZATCA_SLA_BATCH_SIZE=50
ZATCA_SLA_WARN_MS=64800000         # 18h → retry submission
ZATCA_SLA_BREACH_MS=82800000       # 23h → fire ops-alerter

# ─── Post-deploy smoke probes ───────────────────────────────────────────────
# Used by backend/scripts/post-deploy-smoke.js. Defaults to local app.
SMOKE_BASE_URL=http://127.0.0.1:5000
# Optional bearer token for auth-gated probes (not set in deploy by default).
SMOKE_AUTH_TOKEN=

# ══════════════════════════════════════════════════════════════════════════════
# Backend env-var index (added 2026-05-02 — backfill of ratchet baseline)
#
# Every variable referenced by `backend/services|scripts|startup|config`
# is listed here. Most are commented out (`# NAME=`) — that still counts
# as "documented" for the drift guard. An operator turning a knob fills
# in the value; an operator looking up a flag finds it here.
#
# Ordered by domain; secrets show no sample value. See the runbooks in
# docs/blueprint/ for the full operational meaning of each block.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Database ───────────────────────────────────────────────────────────────
# DB_NAME=alawael                                # mongoose db override
# MONGODB_URI=mongodb://...                        # alt name (legacy)
# DB_POOL_SIZE=20
# DB_TLS=true                                    # enforce TLS on Atlas / prod
# DB_INITIAL_RETRY_DELAY=500
# DB_MAX_RETRIES=10
# DB_MAX_RETRY_DELAY=30000
# DB_BACKOFF_MULTIPLIER=2
# MONGOOSE_DEBUG=false
# MONGO_MAX_QUERY_LIMIT=1000
# LOG_ALL_QUERIES=false
# SLOW_QUERY_THRESHOLD_MS=300
# FORCE_DDD_INDEX_SYNC=false                     # one-shot index reflow

# ─── Database backups (legacy mongodump, separate from BACKUP_ENCRYPTION_KEY) ─
# DB_BACKUP_DIR=./backups
# DB_BACKUP_KEEP_DAYS=14
# DB_BACKUP_COMPRESS=true
# DB_BACKUP_MAX_SIZE_MB=2048
# BACKUP_DIR=./backups                           # umbrella dir for new + legacy
# ENABLE_AUTO_BACKUP=true

# ─── Redis (cache + rate-limit + queue locks) ───────────────────────────────
# REDIS_ENABLED=true
# REDIS_HOST=127.0.0.1
# REDIS_DB=0
# REDIS_PREFIX=alawael:
# REDIS_TLS=false
# REDIS_NODE_1=                                  # cluster nodes — leave blank
# REDIS_NODE_2=                                  # for single-node Redis
# REDIS_NODE_3=
# CACHE_TTL=300
# USE_MOCK_CACHE=false                           # in-memory fallback for dev

# ─── Email / SMTP ───────────────────────────────────────────────────────────
# EMAIL_SERVICE=gmail                            # 'gmail' | 'smtp' | 'sendgrid'
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=
# EMAIL_PASSWORD=
# EMAIL_FROM_ADDRESS=no-reply@alaweal.org
# EMAIL_SECURE=false                             # true for port 465
# EMAIL_TEMPLATES_DIR=./backend/services/email/templates
# SMTP_TLS_REJECT_UNAUTHORIZED=true              # set false ONLY for dev
# EMAIL_DEDUP_WINDOW_MS=300000                   # 5 min replay-suppression
# EMAIL_EVENT_BRIDGE=true                        # forward outbox events to bus
# EMAIL_CB_FAILURE_THRESHOLD=5                   # circuit-breaker
# EMAIL_CB_SUCCESS_THRESHOLD=2
# EMAIL_CB_COOLDOWN_MS=60000
# EMAIL_CB_MONITOR_WINDOW=60000

# ─── Encryption + secret material (NOT backups — see BACKUP_ENCRYPTION_KEY) ─
# ENCRYPTION_KEY=                                # legacy app-level secrets
# ENCRYPTION_MASTER_KEY=                         # KMS-style envelope key
# PASSPORT_ENABLE_ENCRYPTION=true
# PASSPORT_CACHE_SIZE=500
# PASSPORT_CACHE_TTL=600
# QR_SECRET=                                     # signed QR for badges/sessions
# INTEGRATION_SECRET=                            # cross-service HMAC

# ─── HR audit retention + anomaly detection ─────────────────────────────────
# HR_AUDIT_ARCHIVE_AFTER_DAYS=365                # tier hot → archive
# HR_AUDIT_PURGE_AFTER_DAYS=1095                 # 3y; PDPL retention envelope
# HR_AUDIT_BATCH_SIZE=500
# HR_RETENTION_POLICY_JSON=                      # override JSON for policies
# HR_SYNC_EXPIRING_SOON_DAYS=30
# HR_ANOMALY_WINDOW_MINUTES=60
# HR_ANOMALY_COOLDOWN_MINUTES=15
# HR_ANOMALY_READS_PER_HOUR=200
# HR_ANOMALY_EXPORTS_PER_DAY=20

# ─── NPHIES (insurance claims, FHIR R4) ─────────────────────────────────────
# NPHIES_ACCESS_TOKEN=                           # OAuth bearer
# NPHIES_LICENSE_ID=                             # SDAIA-issued
# NPHIES_SENDER_ID=                              # branch-bound
# NPHIES_TIMEOUT_MS=30000
# NPHIES_RECON_INTERVAL_MS=900000                # 15 min reconciliation tick
# NPHIES_RECON_BATCH_SIZE=50
# NPHIES_RECON_MIN_AGE_MS=60000
