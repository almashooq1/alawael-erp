# ═══════════════════════════════════════════════════════════════════════════════
# Al-Awael ERP — Docker Compose Environment Variables
# Copy to .env and set real values before running docker compose up
# ═══════════════════════════════════════════════════════════════════════════════

# ─── REQUIRED SECRETS (no defaults — compose will fail if unset) ─────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=          # ← set a strong password
REDIS_PASSWORD=               # ← set a strong password
JWT_SECRET=                   # ← generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── Ports ───────────────────────────────────────────────────────────────────
MONGO_PORT=27017
REDIS_PORT=6379
BACKEND_PORT=3001
FRONTEND_PORT=3004
GATEWAY_PORT=8080
WHATSAPP_PORT=3010
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ─── Frontend ────────────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8080/api

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_EXPIRE=7d

# ─── WhatsApp (optional) ────────────────────────────────────────────────────
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_ID=
# WHATSAPP_WEBHOOK_SECRET=

# ─── GraphQL Server ──────────────────────────────────────────────────────────
GRAPHQL_PORT=4000
# GRAPHQL_PLAYGROUND=true
# GRAPHQL_INTROSPECTION=true

# ─── Finance Module ──────────────────────────────────────────────────────────
FINANCE_PORT=3030

# ─── Supply Chain Management ─────────────────────────────────────────────────
SCM_BACKEND_PORT=3040
SCM_FRONTEND_PORT=3045

# ─── Dashboard ───────────────────────────────────────────────────────────────
DASHBOARD_API_PORT=3006
DASHBOARD_UI_PORT=3007

# ─── AI Services ────────────────────────────────────────────────────────────
# OPENAI_API_KEY=
AGENT_PORT=3020
SECRETARY_PORT=3050

# ─── Python ML Service ──────────────────────────────────────────────────────
PYTHON_ML_PORT=5001

# ─── Monitoring (--profile monitoring) ───────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3060
# GRAFANA_USER=admin
# GRAFANA_PASSWORD=Admin2026!
LOKI_PORT=3100
ALERTMANAGER_PORT=9093
# NODE_EXPORTER_PORT=9100
# REDIS_EXPORTER_PORT=9121

# ─── Optional: PostgreSQL (--profile optional) ──────────────────────────────
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_DB=alawael_erp
# POSTGRES_PORT=5432

# ─── Optional: Elasticsearch (--profile optional) ───────────────────────────
# ELASTICSEARCH_PORT=9200
# KIBANA_PORT=5601

# ─── NATS Message Broker ─────────────────────────────────────────────────────
NATS_PORT=4222
NATS_MONITOR_PORT=8222

# ─── MinIO Object Storage ───────────────────────────────────────────────────
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=                 # ← set a strong password (min 8 chars)
MINIO_BACKUP_BUCKET=alawael-backups

# ─── Notification Service ───────────────────────────────────────────────────
NOTIFICATION_PORT=3070
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@alawael.com
# FCM_PROJECT_ID=

# ─── Queue Worker ───────────────────────────────────────────────────────────
QUEUE_WORKER_PORT=3080

# ─── Backup Service ─────────────────────────────────────────────────────────
BACKUP_PORT=3090
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# ─── Log Aggregator ─────────────────────────────────────────────────────────
LOG_AGGREGATOR_PORT=3095

# ─── Jaeger Tracing (--profile monitoring) ───────────────────────────────────
# JAEGER_UI_PORT=16686
# JAEGER_COLLECTOR_PORT=14268

# ─── Dev Tools (--profile dev) ──────────────────────────────────────────────
# MONGO_EXPRESS_PORT=8081
# MONGO_EXPRESS_USER=admin
# MONGO_EXPRESS_PASSWORD=admin123
# MAILHOG_SMTP_PORT=1025
# MAILHOG_UI_PORT=8025
# REDIS_COMMANDER_PORT=8082

