# ════════════════════════════════════════════════════════════════════════════════
# Al-Awael ERP — Production Environment Template
# نظام الأوائل ERP — قالب إعدادات الإنتاج
#
# تعليمات:
# 1. انسخ هذا الملف: cp .env.production.template .env
# 2. غيّر جميع القيم المحددة بـ CHANGE_ME
# 3. شغّل: node backend/validate-env.js .env
# ════════════════════════════════════════════════════════════════════════════════

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
APP_NAME=alawael-erp
APP_VERSION=1.0.0
TZ=Asia/Riyadh

# ─── Database (MongoDB Atlas) ─────────────────────────────────────────────────
# أنشئ حساب على https://cloud.mongodb.com واستبدل الرابط
MONGODB_URI=CHANGE_ME_MONGODB_ATLAS_URI
MONGODB_MAX_POOL_SIZE=50
USE_MOCK_DB=false

# ─── Redis ────────────────────────────────────────────────────────────────────
# إذا لم تستخدم Redis، اتركه معطلاً
REDIS_URL=CHANGE_ME_REDIS_URL
REDIS_ENABLED=false
DISABLE_REDIS=true

# ─── JWT Authentication ──────────────────────────────────────────────────────
# مهم جداً: ولّد مفاتيح عشوائية قوية بـ:
# node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=CHANGE_ME_JWT_SECRET_64_BYTES
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET_64_BYTES
JWT_REFRESH_EXPIRY=7d

# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_64_BYTES

# ─── URLs & CORS ─────────────────────────────────────────────────────────────
# Domain: alawael.org
FRONTEND_URL=https://alawael.org
CORS_ORIGINS=https://alawael.org
CORS_ORIGIN=https://alawael.org
BACKEND_URL=https://alawael.org
API_BASE_URL=https://alawael.org/api

# ─── Email / SMTP ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME_EMAIL
SMTP_PASS=CHANGE_ME_APP_PASSWORD
EMAIL_FROM=noreply@alawael.org

# ─── Security ────────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=warn
LOG_FORMAT=json

# ─── Backup ──────────────────────────────────────────────────────────────────
ENABLE_AUTO_BACKUP=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# ─── Features ────────────────────────────────────────────────────────────────
ENABLE_SWAGGER=false
SMART_TEST_MODE=false
