# ═══════════════════════════════════════════════════════════════
# Al-Awael ERP — .gitignore
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# 1. Dependencies
# ───────────────────────────────────────────────────────────────
node_modules/
yarn.lock
pnpm-lock.yaml
.npm
.node_repl_history

# ───────────────────────────────────────────────────────────────
# 2. Environment & Secrets  ⚠️  CRITICAL — never commit secrets
# ───────────────────────────────────────────────────────────────
# Root & any nested .env files (covers all subdirectories)
.env
.env.*
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example
!.env.example
!.env.production.template
!backend/.env.production.template

# Legacy explicit entries (kept for safety)
.env.local
.env.*.local
.env.docker
.env.production
deploy/**/.env*
!deploy/**/.env*.example

# Sensitive files
**/find-password*
**/generate-hash*
**/register.json
**/login.json
_archived/security-debris/

# ───────────────────────────────────────────────────────────────
# 3. Build Outputs & Source Maps
# ───────────────────────────────────────────────────────────────
dist/
build/
out/
.next/
coverage/
.nyc_output/
.jest-cache/
**/.jest-cache/
*.js.map
*.ts.map
*.css.map
*.map

# ───────────────────────────────────────────────────────────────
# 4. Logs & Runtime
# ───────────────────────────────────────────────────────────────
maintenance.flag
*.log
*.log.*
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pids/
*.pid
*.seed
*.pid.lock

# Seed runner outputs (backend/seed.out, backend/seed.err)
seed.out
seed.err

# ───────────────────────────────────────────────────────────────
# 5. Temp & Cache
# ───────────────────────────────────────────────────────────────
tmp/
temp/
.tmp/
.cache/
*.tmp
*.temp
docker_volumes/
.docker/
docker-compose.override.local.yml

# Claude CLI session artifacts (cwd marker files + config)
tmpclaude-*
**/tmpclaude-*
.claude/
nul

# ───────────────────────────────────────────────────────────────
# 6. SSL & Certificates
# ───────────────────────────────────────────────────────────────
ssl/
certs/
*.pem
*.key
*.crt

# ───────────────────────────────────────────────────────────────
# 7. IDE & OS
# ───────────────────────────────────────────────────────────────
.vscode/launch.json
.vscode/tasks.json
.vscode/extensions.json
.vscode/settings.json.backup*
.vscode/*.log
# Keep settings.json for consistent configuration
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ───────────────────────────────────────────────────────────────
# 8. Large Binaries & ML Models
# ───────────────────────────────────────────────────────────────
*.exe
*.dll
*.o
*.so
*.dylib
tensorflow.dll
tensorflow.lib
tensorflow/
esbuild.exe
mongod-*.exe
*.pb
*.ckpt
*.pth
*.h5
*.model
intelligent-agent/node_modules/
intelligent-agent/dist/
intelligent-agent/.next/
intelligent-agent/models/

# ───────────────────────────────────────────────────────────────
# 9. Testing Outputs
# ───────────────────────────────────────────────────────────────
test-results/
playwright-report/
jest-*.txt
jest_*.txt
jest-output.json
jest-*.json
test_*.txt
test-results*.txt
backend/.test-mongo-uri
backend/.test-mongo-dbpath

# ───────────────────────────────────────────────────────────────
# 10. Uploads & Misc
# ───────────────────────────────────────────────────────────────
uploads/
backups/
.pytest_cache/
__pycache__/
*.pyc
.db
*.db-journal
**/chrome/*
**/plugins/*
**/extensions/*
# Exception: our domains/extensions/ source code is not a browser extension
!backend/domains/extensions/**
# Exception: our database/plugins/ contains mongoose plugins, not browser plugins
!backend/database/plugins/**

# ───────────────────────────────────────────────────────────────
# 11. Temp Scripts & Debug (ops/ directory)
# Contains VPS deploy/debug scripts with credentials — keep ignored.
# EXCEPTION: monitoring infrastructure-as-code (Prometheus / AlertManager /
# Grafana provisioning) IS committed — the W1404/W1405 deploy gate requires
# these files in git. Negations below re-include exactly those, nothing else.
# ───────────────────────────────────────────────────────────────
ops/*
!ops/prometheus.yml
!ops/alerting-rules.yml
!ops/alertmanager.yml
!ops/loki-rules-w1437.yml
!ops/grafana/
_*.py
!**/__init__.py
_*.js
_*.txt
_*.ps1
_*.json
_*.tmp
__*.txt

# Legitimate source files that match `_*.js` above but are NOT dev-only
# scratch — they're real shared libraries / canonical schemas. CI fails
# without them. Discovered 2026-05-26 via Cycle 10 CI investigation:
# 22 canonical schemas import `../_primitives` → Sprint Tests broke.
!backend/intelligence/canonical/_primitives.js

# ───────────────────────────────────────────────────────────────
# 11b. Root-level Python debug/deploy scripts (~250 files)
# These are dev-only diagnostic scripts, NOT part of the app
# ───────────────────────────────────────────────────────────────
/*.py

# ───────────────────────────────────────────────────────────────
# 12. Session Reports & Audit Files
# ───────────────────────────────────────────────────────────────
AUDIT_REPORT.md
AUDIT_SESSION_*.md
CODE_QUALITY_AUDIT_*.md
E2E_TESTING_*.md
FRONTEND_BUG_REPORT.md
TASK*_PHASES_*.md
BACKEND_AUDIT_REPORT.md
eslint-results.json
performance-test-*.json
port*-process.json
dead-analysis.txt
dead-files-report.txt
build_output.txt
build-output.txt

# ───────────────────────────────────────────────────────────────
# 14. Frontend Build Helper Scripts (dev-only temp files)
# ───────────────────────────────────────────────────────────────
frontend/build-result.txt
frontend/build-output.txt
frontend/capture-build.cjs
frontend/fix-map-i.cjs
frontend/fix-unused-imports.cjs
frontend/fix-unused-imports.js
frontend/run-build.bat
frontend/find-palette-imports.js
frontend/*.bat
frontend/*.cjs

# ───────────────────────────────────────────────────────────────
# 13. Archived Code & Legacy Backups
# ───────────────────────────────────────────────────────────────
_archived/
_archive/
**/_archive/

# ───────────────────────────────────────────────────────────────
# 15. VPS Deployment Scripts (contain credentials - never commit)
# ───────────────────────────────────────────────────────────────
vps_*.py
vps_*.txt
fix_*.py
fix_*.js
fix_log.txt
fix_palette.js
fix_final.js
build2.txt
build_final.txt
build_warnings.txt
check_remaining.js
test.txt
test2.txt
test3.txt
testwrite.txt
test_redis.js

# ───────────────────────────────────────────────────────────────
# 16. GitHub Actions & Deployment Utility Scripts
# ───────────────────────────────────────────────────────────────
add_missing_secrets.py
check_deploy.py
check_deploy_logs.py
check_new_run.py
fetch_logs.py
wait_and_check.py
update_github_secret.py
update_ssh_key.py
run_jobs*.json
run_status.json
run2_*.json
run3_*.json
runs*.json
deploy_logs*.txt
deploy_logs*.zip

# Diagnostic/utility scripts
check_duplicates.js
check_status.js
project_health_report.js
check_remaining.js
backend/check_app.js
backend/check_routes.js
backend/trace_indexes.js
backend/fix_last4.js
backend/fix_indexes_v2.js
backend/fix_duplicate_models.js

# ───────────────────────────────────────────────────────────────
# Dead code & generated caches — never track these
# ───────────────────────────────────────────────────────────────
**/_archived/
**/__pycache__/
**/*.pyc
**/*.pyo
