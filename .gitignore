# ═══════════════════════════════════════════════════════════════
# Al-Awael ERP — .gitignore
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# 1. Dependencies
# ───────────────────────────────────────────────────────────────
node_modules/
yarn.lock
.npm
.node_repl_history

# ───────────────────────────────────────────────────────────────
# 2. Environment & Secrets
# ───────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.docker
.env.production
deploy/**/.env*
!deploy/**/.env*.example
**/find-password*
**/generate-hash*
**/register.json
**/login.json
intelligent-agent/backend/.env
_archived/security-debris/

# ───────────────────────────────────────────────────────────────
# 3. Build Outputs & Source Maps
# ───────────────────────────────────────────────────────────────
dist/
build/
out/
.next/
coverage/
.nyc_output/
.jest-cache/
**/.jest-cache/
*.js.map
*.ts.map
*.css.map
*.map

# ───────────────────────────────────────────────────────────────
# 4. Logs & Runtime
# ───────────────────────────────────────────────────────────────
*.log
*.log.*
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pids/
*.pid
*.seed
*.pid.lock

# ───────────────────────────────────────────────────────────────
# 5. Temp & Cache
# ───────────────────────────────────────────────────────────────
tmp/
temp/
.tmp/
.cache/
*.tmp
*.temp
docker_volumes/
.docker/
docker-compose.override.local.yml

# ───────────────────────────────────────────────────────────────
# 6. SSL & Certificates
# ───────────────────────────────────────────────────────────────
ssl/
certs/
*.pem
*.key
*.crt

# ───────────────────────────────────────────────────────────────
# 7. IDE & OS
# ───────────────────────────────────────────────────────────────
.vscode/launch.json
.vscode/tasks.json
.vscode/extensions.json
.vscode/settings.json.backup*
.vscode/*.log
# Keep settings.json for consistent configuration
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ───────────────────────────────────────────────────────────────
# 8. Large Binaries & ML Models
# ───────────────────────────────────────────────────────────────
*.exe
*.dll
*.o
*.so
*.dylib
tensorflow.dll
tensorflow.lib
tensorflow/
esbuild.exe
mongod-*.exe
*.pb
*.ckpt
*.pth
*.h5
*.model
intelligent-agent/node_modules/
intelligent-agent/dist/
intelligent-agent/.next/
intelligent-agent/models/

# ───────────────────────────────────────────────────────────────
# 9. Testing Outputs
# ───────────────────────────────────────────────────────────────
test-results/
playwright-report/
jest-*.txt
jest_*.txt
jest-output.json
jest-*.json
test_*.txt
test-results*.txt
backend/.test-mongo-uri

# ───────────────────────────────────────────────────────────────
# 10. Uploads & Misc
# ───────────────────────────────────────────────────────────────
uploads/
backups/
.pytest_cache/
__pycache__/
*.pyc
.db
*.db-journal
**/chrome/*
**/plugins/*
**/extensions/*

# ───────────────────────────────────────────────────────────────
# 11. Temp Scripts & Debug (ops/ directory)
# Contains VPS deploy/debug scripts with credentials
# ───────────────────────────────────────────────────────────────
ops/
_*.py
!**/__init__.py
_*.js
_*.txt
_*.ps1
_*.json
_*.tmp
__*.txt

# ───────────────────────────────────────────────────────────────
# 12. Session Reports & Audit Files
# ───────────────────────────────────────────────────────────────
AUDIT_REPORT.md
AUDIT_SESSION_*.md
CODE_QUALITY_AUDIT_*.md
E2E_TESTING_*.md
FRONTEND_BUG_REPORT.md
TASK*_PHASES_*.md
BACKEND_AUDIT_REPORT.md
eslint-results.json
performance-test-*.json
port*-process.json
dead-analysis.txt
dead-files-report.txt
build_output.txt
build-output.txt

# ───────────────────────────────────────────────────────────────
# 14. Frontend Build Helper Scripts (dev-only temp files)
# ───────────────────────────────────────────────────────────────
frontend/build-result.txt
frontend/build-output.txt
frontend/capture-build.cjs
frontend/fix-map-i.cjs
frontend/fix-unused-imports.cjs
frontend/fix-unused-imports.js
frontend/run-build.bat
frontend/find-palette-imports.js
frontend/*.bat
frontend/*.cjs

# ───────────────────────────────────────────────────────────────
# 13. Archived Code & Legacy Backups
# ───────────────────────────────────────────────────────────────
_archived/
