#!/bin/sh
# Platform-wide pre-push gate: enforces zero-warning lint on all subprojects
# plus backend's deeper push checks. SCM backend is a placeholder lint.

set -e

# 2026-05-26 (Cycle 11): block the recurring sprint-tests.yml drift class
# at the push gate. Drift caught HERE means CI can never go red on it
# again — fired 3× this session (W269d-g batch + W269h solo + W440)
# before this guard. Fast (<1s); failure prints missing entries +
# suggests `npm run sync:sprint-paths` for the one-command auto-fix.
echo "[pre-push] sprint-tests.yml drift check…"
cd backend && npm run check:sprint-paths
cd ..

# 2026-05-26 (Cycle 11): block TDZ-class bugs at the push gate. Loads
# every routes/**/*.routes.js + reports any that throw on require.
# Caught W441 TDZ in 8 files (commit a870736ae) — broke 100+ admin
# routes silently. ~10 sec. Ignores mongoose 'already compiled' + env
# load failures (known false-positive classes).
echo "[pre-push] route-load smoke (TDZ class detector)…"
cd backend && npm run check:routes-load
cd ..

# 2026-05-26 Cycle 11: block tracked-source-files-matching-gitignore
# class. Caught the _primitives.js silent-break - intelligence/canonical
# _primitives.js required by 22 schemas, matched the underscore-star-js
# rule, CI clone broke while local sprint passed. Fast under 1s.
# Baseline is in scripts/check-gitignored-sources.js - any NEW tracked-
# ignored file requires either a negation rule in .gitignore preferred
# or an explicit baseline entry with comment.
echo "[pre-push] gitignored-source-files drift check…"
cd backend && npm run check:gitignored-sources
cd ..

# 2026-05-27 (Cycle 12): block Mongoose mixed pre/post hook styles
# (async + callback) on the SAME event — Kareem dispatches the whole
# chain via Promise adapters when ANY hook is async, leaving `next`
# undefined for callback siblings → TypeError on every doc.save().
# Caught W465→W483 (Complaint.js mix → parent-portal-v2 CI red ~24h)
# AND a second live case in measurement/QuickAssessment.model.js
# during gate development. <1s static scan of backend/models/**/*.js.
echo "[pre-push] mongoose hook-style drift check…"
cd backend && npm run check:hook-style
cd ..

# 2026-05-27: block Wave-number collisions across the 66666/ +
# alawael-rehab-platform/ repo pair before they reach a remote. Two
# parallel-running agents have collided on the same WNNN 15+ times in
# the W381→W508 range (see project_security_w471_w508 memory note).
# Each collision costs ~30 min after-the-fact untangling. Scans last
# N commits in both repos (~1s); fails with a one-line "suggested next
# free wave: WNNN" + 3-recipe fix block. Bypass with CHECK_WAVE_SKIP=1
# for coordinated multi-repo waves (rare).
echo "[pre-push] wave-number collision check…"
cd backend && npm run check:wave-collision
cd ..

# 2026-05-28 (W531): block Express route-ordering shadowing — a literal
# route declared AFTER a same-shape :param sibling is unreachable (the
# param route wins and casts the literal segment as a Mongo ObjectId →
# 500). Found app-wide while auditing HR (72 pre-existing across ~30
# files, biometric/branch fixed + rest baselined to ratchet down). Pure
# source scan (<1s). Failure names file + literal + shadowing param; fix
# is to move the literal's declaration above the :param route.
echo "[pre-push] route-shadowing check (literal route after :param sibling)…"
cd backend && npm run check:route-shadowing
cd ..

echo "[pre-push] backend quality:push…"
cd backend && npm run quality:push
cd ..

echo "[pre-push] frontend lint (--max-warnings=0)…"
cd frontend && npm run lint
cd ..

echo "[pre-push] supply-chain-management/frontend lint (--max-warnings=0)…"
cd supply-chain-management/frontend && npm run lint
cd ../..

echo "[pre-push] mobile lint (--max-warnings=0)…"
cd mobile && npm run lint
cd ..

echo "[pre-push] ✅ all lint gates passed"
