#!/bin/sh
# Platform-wide pre-push gate: enforces zero-warning lint on all subprojects
# plus backend's deeper push checks. SCM backend is a placeholder lint.

set -e

# 2026-05-26 (Cycle 11): block the recurring sprint-tests.yml drift class
# at the push gate. Drift caught HERE means CI can never go red on it
# again — fired 3× this session (W269d-g batch + W269h solo + W440)
# before this guard. Fast (<1s); failure prints missing entries +
# suggests `npm run sync:sprint-paths` for the one-command auto-fix.
echo "[pre-push] sprint-tests.yml drift check…"
cd backend && npm run check:sprint-paths
cd ..

# 2026-05-26 (Cycle 11): block TDZ-class bugs at the push gate. Loads
# every routes/**/*.routes.js + reports any that throw on require.
# Caught W441 TDZ in 8 files (commit a870736ae) — broke 100+ admin
# routes silently. ~10 sec. Ignores mongoose 'already compiled' + env
# load failures (known false-positive classes).
echo "[pre-push] route-load smoke (TDZ class detector)…"
cd backend && npm run check:routes-load
cd ..

# 2026-05-26 (Cycle 11): block tracked-source-files-matching-gitignore
# class. Caught the _primitives.js silent-break (intelligence/canonical
# /_primitives.js required by 22 schemas, matched the `_*.js` rule, CI
# clone broke while local sprint passed). Fast (<1s). Baseline is in
# scripts/check-gitignored-sources.js — any NEW tracked-ignored file
# requires either a `!` negation in .gitignore (preferred) or an
# explicit baseline entry with comment.
echo "[pre-push] gitignored-source-files drift check…"
cd backend && npm run check:gitignored-sources
cd ..

echo "[pre-push] backend quality:push…"
cd backend && npm run quality:push
cd ..

echo "[pre-push] frontend lint (--max-warnings=0)…"
cd frontend && npm run lint
cd ..

echo "[pre-push] supply-chain-management/frontend lint (--max-warnings=0)…"
cd supply-chain-management/frontend && npm run lint
cd ../..

echo "[pre-push] mobile lint (--max-warnings=0)…"
cd mobile && npm run lint
cd ..

echo "[pre-push] ✅ all lint gates passed"
