{
  // ═══════════════════════════════════════════════════════════
  // VS Code Settings - Optimized for Large Projects
  // تحسينات جذرية للمشاريع الضخمة
  // ═══════════════════════════════════════════════════════════

  // ────────────────────────────────────────────────────────────
  // 🔥 CRITICAL: Disable Heavy Extensions
  // ────────────────────────────────────────────────────────────

  // Git: Completely disable for performance
  "git.enabled": false,
  "git.autoRepositoryDetection": false,
  "git.decorations.enabled": false,
  "git.ignoreMissingGitWarning": true,
  "scm.decorations.enabled": false,

  // TypeScript: Reduce overhead - AGGRESSIVE SETTINGS
  "typescript.tsserver.maxTsServerMemory": 4096,
  "typescript.tsserver.watchOptions": {
    "watchDirectory": "dynamicPriorityPolling",
    "watchFile": "dynamicPriorityPolling",
    "fallbackPolling": "dynamicPriorityPolling",
    "synchronousWatchDirectory": false
  },
  "typescript.check.npmIsInstalled": false,
  "typescript.surveys.enabled": false,
  "typescript.suggest.enabled": true,
  "typescript.implementationsCodeLens.enabled": false,
  "typescript.referencesCodeLens.enabled": false,
  "typescript.updateImportsOnFileMove.enabled": "never",
  "typescript.disableAutomaticTypeAcquisition": true,

  // ESLint: Disable auto-fix to reduce CPU
  "eslint.enable": true,
  "eslint.run": "onSave",
  "eslint.validate": ["javascript", "typescript"],
  "eslint.workingDirectories": [{ "pattern": "./backend" }, { "pattern": "./frontend" }, { "pattern": "./mobile" }],

  // ────────────────────────────────────────────────────────────
  // 📂 File Watching & Exclusions
  // ────────────────────────────────────────────────────────────

  // Completely exclude from workspace
  "files.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/*.map": true,
    "**/dist": true,
    "**/build": true,
    "**/coverage": true,
    "**/.next": true,
    "**/out": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/*.log": true,
    "**/package-lock.json": false // Keep visible for npm management
  },

  // Exclude from search
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/coverage": true,
    "**/*.map": true,
    "**/.next": true,
    "**/out": true,
    "**/*.log": true,
    "**/package-lock.json": true
  },

  // CRITICAL: Disable file watching for heavy directories
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/coverage/**": true,
    "**/.next/**": true,
    "**/out/**": true,
    "**/*.map": true,
    "**/*.log": true,
    "**/intelligent-agent/node_modules/**": true,
    "**/backend/node_modules/**": true,
    "**/frontend/node_modules/**": true,
    "**/mobile/node_modules/**": true,
    "**/supply-chain-management/**/node_modules/**": true,
    "**/whatsapp/node_modules/**": true,
    "**/graphql/node_modules/**": true,
    "**/erp_new_system/**/node_modules/**": true,
    "**/.terraform/**": true,
    "**/terraform.tfstate*": true,
    "**/.vscode-test/**": true,
    "**/.nyc_output/**": true,
    "**/tmp/**": true,
    "**/temp/**": true
  },

  // ────────────────────────────────────────────────────────────
  // 🔧 Editor Settings
  // ────────────────────────────────────────────────────────────

  "editor.fontSize": 13,
  "editor.wordWrap": "on",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "never" // Disabled for performance
  },
  "editor.quickSuggestions": {
    "other": "inline",
    "comments": false,
    "strings": false
  },
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.suggest.preview": false,
  // editor.suggest.maxVisibleSuggestions removed (deprecated - widget is resizable)
  "editor.suggest.shareSuggestSelections": false,
  "editor.suggest.showStatusBar": false,
  "editor.parameterHints.enabled": false,
  "editor.hover.enabled": "on",
  "editor.hover.delay": 500,
  "editor.lightbulb.enabled": "off",
  "editor.renderWhitespace": "none",
  "editor.minimap.enabled": false,

  // ────────────────────────────────────────────────────────────
  // 🎨 Formatter Configuration
  // ────────────────────────────────────────────────────────────

  "[javascript]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[python]": {
    "editor.formatOnSave": false, // Disabled - no Python formatter installed
    "editor.defaultFormatter": null
  },

  // ────────────────────────────────────────────────────────────
  // 🌐 Language Servers
  // ────────────────────────────────────────────────────────────

  "json.enableSchemaDownload": false,
  "markdown.validate.enabled": false,
  "css.validate": false,
  "less.validate": false,
  "scss.validate": false,

  // ────────────────────────────────────────────────────────────
  // 🚫 Disable Heavy Features
  // ────────────────────────────────────────────────────────────

  "telemetry.telemetryLevel": "off",
  "workbench.startupEditor": "none",
  "workbench.settings.enableNaturalLanguageSearch": false,
  "workbench.colorTheme": "Default Dark Modern",
  "window.zoomLevel": 0,
  "extensions.ignoreRecommendations": true,
  "security.workspace.trust.enabled": false,

  // Python
  "python.linting.enabled": false,
  "python.formatting.provider": "none",

  // ────────────────────────────────────────────────────────────
  // 🔌 Extension-Specific Settings
  // ────────────────────────────────────────────────────────────

  // HashiCorp Terraform - CRITICAL: Exclude node_modules
  "terraform.experimentalFeatures.validateOnSave": false,
  "terraform.validation.enableEnhancedValidation": false,
  "terraform.languageServer.enable": true,
  "terraform.languageServer.path": "",
  "terraform.languageServer.args": [],
  "terraform.codelens.referenceCount": false,
  "terraform.indexing.enabled": false, // Disable automatic indexing
  "terraform.search.exclude": ["**/node_modules/**", "**/dist/**", "**/build/**", "**/intelligent-agent/**", "**/.git/**"],

  // Docker - Reduce overhead
  "docker.explorerRefreshInterval": 10000,

  // GitHub Actions - Disable auto-validation
  "github-actions.workflows.pinned.refresh.enabled": false,

  // Copilot - Keep enabled but optimize
  "github.copilot.enable": {
    "*": true,
    "yaml": false,
    "plaintext": false,
    "markdown": false
  },

  // ────────────────────────────────────────────────────────────
  // 📊 Debugging & Terminal
  // ────────────────────────────────────────────────────────────

  "debug.console.wordWrap": false,
  "debug.internalConsoleOptions": "neverOpen",
  "terminal.integrated.enableMultiLinePasteWarning": "auto",
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell",
      "args": ["-NoLogo"]
    },
    "PowerShell (UTF-8)": {
      "path": "pwsh.exe",
      "args": [
        "-NoLogo",
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "[Console]::OutputEncoding = [System.Text.Encoding]::UTF8; [Console]::InputEncoding = [System.Text.Encoding]::UTF8; $OutputEncoding = [System.Text.Encoding]::UTF8"
      ],
      "icon": "terminal-powershell"
    },
    "Windows PowerShell": {
      "path": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
      "args": ["-NoLogo"],
      "icon": "terminal-powershell"
    }
  },
  "terminal.integrated.fontFamily": "Cascadia Code, Consolas, 'Courier New', monospace",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.lineHeight": 1.2,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.fastScrollSensitivity": 5,
  "terminal.integrated.mouseWheelScrollSensitivity": 2,
  "terminal.integrated.smoothScrolling": false,
  "terminal.integrated.env.windows": {
    "PYTHONUTF8": "1",
    "LC_ALL": "en_US.UTF-8",
    "LANG": "en_US.UTF-8"
  },

  // ────────────────────────────────────────────────────────────
  // 🧹 Additional Optimizations
  // ────────────────────────────────────────────────────────────

  "files.autoSave": "off",
  "files.hotExit": "onExitAndWindowClose",
  "files.defaultLanguage": "javascript",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.associations": {
    "*.json": "jsonc",
    ".env*": "dotenv"
  },

  // Emmet - Disable for performance
  "emmet.triggerExpansionOnTab": false,
  "emmet.showSuggestionsAsSnippets": false,

  // Breadcrumbs
  "breadcrumbs.enabled": true,
  "breadcrumbs.filePath": "on",
  "breadcrumbs.symbolPath": "off",

  // ────────────────────────────────────────────────────────────
  // 🎯 Workspace-Specific
  // ────────────────────────────────────────────────────────────

  "cSpell.words": ["المخاطر", "alawael", "erp", "gosi", "mudarabah", "musharakah", "zakat"],
  "cSpell.configFile": ".cspellrc.json",
  "cSpell.enabled": false, // Disabled for performance

  // ────────────────────────────────────────────────────────────
  // 🚀 ADDITIONAL PERFORMANCE OPTIMIZATIONS
  // ────────────────────────────────────────────────────────────

  // Workspace Settings
  "workbench.enableExperiments": false,
  "workbench.editor.enablePreview": false,
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 10,
  "workbench.editor.limit.perEditorGroup": true,

  // Search Settings (AGGRESSIVE)
  "search.followSymlinks": false,
  "search.quickOpen.includeSymbols": false,
  // search.maintainFileSearchCache removed (deprecated - cache is always maintained)
  "search.collapseResults": "auto",
  "search.maxResults": 5000,

  // JavaScript/TypeScript Performance
  "javascript.updateImportsOnFileMove.enabled": "never",
  "javascript.suggest.enabled": true,
  "javascript.validate.enable": false,

  // File Settings
  "files.maxMemoryForLargeFilesMB": 2048,
  "files.saveConflictResolution": "overwriteFileOnDisk",

  // ────────────────────────────────────────────────────────────
  // 📁 Explorer: File Nesting (Professional Grouping)
  // ────────────────────────────────────────────────────────────

  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "package.json": "package-lock.json, .npmrc, .nvmrc, .node-version, .eslintrc*, eslint.config.*, .prettierrc*, .prettierignore, .editorconfig, .eslintignore, tsconfig.json, jsconfig.json, .vscodeignore, .dockerignore, Procfile, LICENSE",
    "Dockerfile": "docker-compose*.yml, .dockerignore",
    "README.md": "CONTRIBUTING.md, CHANGELOG.md, CODE_OF_CONDUCT.md, SECURITY.md",
    ".gitignore": ".deploymentconfig, .env.example, .env.docker, .env.production, .env.production.template",
    "*.js": "$(capture).test.js, $(capture).spec.js, $(capture).d.ts, $(capture).js.map",
    "*.ts": "$(capture).test.ts, $(capture).spec.ts, $(capture).d.ts, $(capture).js, $(capture).js.map"
  },

  // Explorer
  "explorer.compactFolders": true,
  "explorer.incrementalNaming": "smart",
  "explorer.sortOrder": "type",
  "explorer.sortOrderLexicographicOptions": "unicode",

  // Problems Panel
  "problems.decorations.enabled": false,
  "problems.showCurrentInStatus": true,

  // Outline View
  "outline.problems.enabled": false,
  "outline.problems.badges": false,

  // Additional Extensions
  "html.autoClosingTags": false,
  "css.lint.validProperties": [],
  "less.lint.validProperties": [],
  "scss.lint.validProperties": [],

  // YAML Validation - Disable for Grafana configs
  "yaml.validate": false,
  "yaml.customTags": ["!reference sequence"],

  // TypeScript workspace SDK
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "typescript.preferences.importModuleSpecifier": "relative"
}
