{
    "python-envs.pythonProjects": [],
    "python-envs.defaultEnvManager": "ms-python.python:system",
    "git.ignoreLimitWarning": true,
    "cSpell.words": [
        "المخاطر"
    ],
    "cSpell.configFile": ".cspellrc.json",
    "typescript.tsdk": "node_modules/typescript/lib",
    "typescript.tsserver.pluginPaths": [],
    "typescript.enablePromptUseWorkspaceTsdk": true,
    "typescript.check.npmIsInstalled": false,
    
    "editor.fontSize": 13,
    "editor.wordWrap": "on",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "off"
    },
    "editor.maxTokens": 2000,
    
    // Exclude large and unnecessary files from workspace
    "files.exclude": {
        "**/.git": false,
        "**/node_modules": false,
        "**/*.log": false,
        "dist": false,
        "build": false,
        "coverage": false,
        "**/.DS_Store": true,
        "**/Thumbs.db": true
    },
    
    // Search optimization
    "search.exclude": {
        "**/node_modules": false,
        "**/coverage": true,
        "**/*.map": true,
        "**/dist": true,
        "**/build": true
    },
    
    // File watcher optimization
    "files.watcherExclude": {
        "**/.git": true,
        "**/node_modules": true,
        "**/dist": true,
        "**/build": true,
        "**/coverage": true,
        "**/*.map": true,
        "**/*.log": true
    },
    
    // Disable heavy VS Code features
    "window.zoomLevel": 0,
    "telemetry.telemetryLevel": "off",
    "workbench.startupEditor": "none",
    "workbench.settings.enableNaturalLanguageSearch": false,
    "workbench.colorTheme": "Default Dark Modern",
    
    // Git performance - disable problematic decorations
    "git.autoRepositoryDetection": false,
    "git.ignoreMissingGitWarning": true,
    "git.decorations.enabled": false,
    "scm.decorations.enabled": false,
    
    // Language server optimization
    "[javascript]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescript]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[python]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "ms-python.python"
    },
    
    // Disable extensions that crash extension host
    "extensions.ignoreRecommendations": true,
    
    // Reduce memory usage
    "security.workspace.trust.enabled": false,
    
    // Disable unnecessary language features
    "markdown.validate.enabled": false,
    "json.enableSchemaDownload": false,
    "python.linting.enabled": false,
    "python.formatting.provider": "none",
    
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    }
}

