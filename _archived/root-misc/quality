main() {
    CMD="${1:-help}"

    case "$CMD" in
        backend)
            run_quality "backend" "quality:ci" "Backend strict quality check"
            ;;
        backend:push)
            run_quality "backend" "quality:push" "Backend fast push quality check"
            ;;
        graphql)
            run_quality "graphql" "quality" "GraphQL quality check"
            ;;
        finance)
            run_quality "finance-module/backend" "quality" "Finance module quality check"
            ;;
        supply-chain)
            run_quality "supply-chain-management/backend" "quality" "Supply chain quality check"
            ;;
        frontend)
            run_quality "supply-chain-management/frontend" "test" "Frontend quality check"
            ;;
        intelligent-agent)
            run_quality "intelligent-agent" "quality:ci" "Intelligent Agent quality check"
            ;;
        mobile)
            run_quality "mobile" "quality:ci" "Mobile app quality check"
            ;;
        gateway)
            run_quality "gateway" "quality:ci" "API Gateway quality check"
            ;;
        whatsapp)
            run_quality "whatsapp" "quality:ci" "WhatsApp Service quality check"
            ;;
        backend-1)
            print_status "backend-1 is legacy; redirecting to backend"
            run_quality "backend" "quality:ci" "Backend quality check (legacy alias: backend-1)"
            ;;
        all)
            run_all_quality
            ;;
        quick)
            run_quick_quality
            ;;
        status)
            show_status
            ;;
        help|-h|--help)
            show_help
            ;;
        *)
            print_error "Unknown command: $CMD"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

main "$@"
