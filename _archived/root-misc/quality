#!/bin/bash

# ALAWAEL Quality Control Command
# Unified interface for all project quality checks
# Usage: ./quality <command>

set -e

RESET='\033[0m'
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'

print_header() {
    echo -e "${BLUE}============================================${RESET}"
    echo -e "${BLUE}$1${RESET}"
    echo -e "${BLUE}============================================${RESET}"
}

print_success() {
    echo -e "${GREEN}✅ $1${RESET}"
}

print_error() {
    echo -e "${RED}❌ $1${RESET}"
}

print_status() {
    echo -e "${YELLOW}⏳ $1${RESET}"
}

run_quality() {
    local project=$1
    local script=$2
    local desc=$3

    print_status "$desc..."
    if (cd "$project" && npm run "$script"); then
        print_success "$desc passed"
        return 0
    else
        print_error "$desc failed"
        return 1
    fi
}

run_all_quality() {
    local failures=0

    print_header "ALAWAEL Full System Quality Check (All 9 Services)"

    # Backend check
    echo ""
    print_status "Backend Quality Gate (strict, all 894 tests, ~35min)..."
    if (cd "backend" && npm run quality:ci); then
        print_success "Backend quality:ci passed"
    else
        print_error "Backend quality:ci failed"
        ((failures++))
    fi

    # GraphQL check
    echo ""
    print_status "GraphQL Quality Check (~5min)..."
    if (cd "graphql" && npm run quality); then
        print_success "GraphQL quality passed"
    else
        print_error "GraphQL quality failed"
        ((failures++))
    fi

    # Finance check
    echo ""
    print_status "Finance Module Quality Check (~5min)..."
    if (cd "finance-module/backend" && npm run quality); then
        print_success "Finance quality passed"
    else
        print_error "Finance quality failed"
        ((failures++))
    fi

    # Supply Chain Backend check
    echo ""
    print_status "Supply Chain Backend Quality Check (~5min)..."
    if (cd "supply-chain-management/backend" && npm run quality); then
        print_success "Supply Chain quality passed"
    else
        print_error "Supply Chain quality failed"
        ((failures++))
    fi

    # Frontend check
    echo ""
    print_status "Frontend Quality Check (~5min)..."
    if (cd "supply-chain-management/frontend" && npm test -- --passWithNoTests 2>/dev/null); then
        print_success "Frontend tests passed"
    else
        print_error "Frontend tests failed"
        ((failures++))
    fi

    # Intelligent Agent check
    echo ""
    print_status "Intelligent Agent Quality Check (~5min)..."
    if (cd "intelligent-agent" && npm run quality:ci); then
        print_success "Intelligent Agent quality passed"
    else
        print_error "Intelligent Agent quality failed"
        ((failures++))
    fi

    # Mobile check
    echo ""
    print_status "Mobile App Quality Check (~5min)..."
    if (cd "mobile" && npm run quality:ci); then
        print_success "Mobile quality passed"
    else
        print_error "Mobile quality failed"
        ((failures++))
    fi

    # Gateway check
    echo ""
    print_status "API Gateway Quality Check (~5min)..."
    if (cd "gateway" && npm run quality:ci); then
        print_success "Gateway quality passed"
    else
        print_error "Gateway quality failed"
        ((failures++))
    fi

    # WhatsApp check
    echo ""
    print_status "WhatsApp Service Quality Check (~5min)..."
    if (cd "whatsapp" && npm run quality:ci); then
        print_success "WhatsApp quality passed"
    else
        print_error "WhatsApp quality failed"
        ((failures++))
    fi

    echo ""
    if [ $failures -eq 0 ]; then
        print_success "All systems quality check PASSED"
        exit 0
    else
        print_error "Some quality checks FAILED ($failures failures)"
        exit 1
    fi
}

run_quick_quality() {
    local failures=0

    print_header "ALAWAEL Quick Quality Check (Smoke Tests - Phase 4A Services)"

    # Backend phase2 subset
    echo ""
    print_status "Backend phase2 tests (fast, ~12min)..."
    if (cd "backend" && npm run quality:push); then
        print_success "Backend phase2 passed"
    else
        print_error "Backend phase2 failed"
        ((failures++))
    fi

    # New Phase 4A services quick checks
    echo ""
    print_status "Intelligent Agent quick check (guard, ~2min)..."
    if (cd "intelligent-agent" && npm run quality:guard 2>/dev/null); then
        print_success "Intelligent Agent guard passed"
    else
        print_status "Intelligent Agent guard skipped"
    fi

    echo ""
    print_status "Mobile quick check (guard, ~2min)..."
    if (cd "mobile" && npm run quality:guard 2>/dev/null); then
        print_success "Mobile guard passed"
    else
        print_status "Mobile guard skipped"
    fi

    echo ""
    print_status "Gateway quick check (lint, ~1min)..."
    if (cd "gateway" && npm run quality:guard 2>/dev/null); then
        print_success "Gateway guard passed"
    else
        print_status "Gateway guard skipped"
    fi

    echo ""
    print_status "WhatsApp quick check (build, ~1min)..."
    if (cd "whatsapp" && npm run quality:guard 2>/dev/null); then
        print_success "WhatsApp guard passed"
    else
        print_status "WhatsApp guard skipped"
    fi

    echo ""
    print_success "Quick quality check PASSED (Phase 4A ready)"
    exit 0
}

