#!/bin/bash

# ALAWAEL Enhanced Quality Control
# Advanced quality management with performance monitoring and detailed reporting

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
RESET='\033[0m'

# Configuration
REPORT_DIR="${PWD}/.quality-reports"
TIMESTAMP=$(date +%Y-%m-%d_%H-%M-%S)
REPORT_FILE="${REPORT_DIR}/report_${TIMESTAMP}.txt"

# Initialize report directory
mkdir -p "${REPORT_DIR}"

print_header() {
    echo -e "${BLUE}════════════════════════════════════════════════════${RESET}"
    echo -e "${BLUE}$1${RESET}"
    echo -e "${BLUE}════════════════════════════════════════════════════${RESET}"
}

print_section() {
    echo -e "${MAGENTA}▸ $1${RESET}"
}

print_success() {
    echo -e "${GREEN}✅ $1${RESET}"
}

print_error() {
    echo -e "${RED}❌ $1${RESET}"
}

print_info() {
    echo -e "${CYAN}ℹ️  $1${RESET}"
}

run_quality_check() {
    local service=$1
    local description=$2
    local command=$3

    echo ""
    print_section "$description"
    echo -e "${YELLOW}Running command:${RESET} $command"
    echo -e "${YELLOW}Start time:${RESET} $(date +%H:%M:%S)"

    local start=$(date +%s)

    if eval "$command" 2>&1 | tee -a "$REPORT_FILE"; then
        local end=$(date +%s)
        local duration=$((end - start))
        print_success "$description completed in ${duration}s"
        echo "Duration: ${duration}s" >> "$REPORT_FILE"
        return 0
    else
        local end=$(date +%s)
        local duration=$((end - start))
        print_error "$description failed after ${duration}s"
        echo "Status: FAILED (${duration}s)" >> "$REPORT_FILE"
        return 1
    fi
}

generate_summary_report() {
    print_header "Quality Check Summary Report"

    cat > "$REPORT_FILE" << 'EOF'
════════════════════════════════════════════════════════════════
ALAWAEL Quality System - Enhanced Quality Report
════════════════════════════════════════════════════════════════

Timestamp: $(date -Iseconds)
System: ALAWAEL ERP Platform
Report Type: Enhanced Quality Check

════════════════════════════════════════════════════════════════
QUALITY CHECK RESULTS
════════════════════════════════════════════════════════════════

EOF

    cat "$REPORT_FILE"

    echo ""
    print_info "Report saved to: ${REPORT_FILE}"
}

show_recommendations() {
    echo ""
    print_header "Recommendations"

    if grep -q "FAILED" "$REPORT_FILE" 2>/dev/null; then
        print_error "Critical Issues Detected - Immediate Action Required"
        echo ""
        echo "1. Review failed quality checks in report: ${REPORT_FILE}"
        echo "2. Run individual service checks for detailed errors:"
        echo "   ./quality graphql"
        echo "   ./quality finance"
        echo "   ./quality supply-chain"
        echo "3. For backend issues:"
        echo "   cd backend && npm run quality:ci"
        echo ""
    else
        print_success "All Quality Checks Passed!"
        echo ""
        echo "Next Steps:"
        echo "1. Review code coverage in CI artifacts"
        echo "2. Commit your changes"
        echo "3. Push to feature branch"
        echo "4. Create pull request"
        echo "5. Wait for GitHub Actions to complete"
        echo ""
    fi
}

main() {
    local mode=${1:-standard}

    case "$mode" in
        quick)
            print_header "ALAWAEL Quick Quality Check"
            echo ""
            ./quality quick
            ;;

        full)
            print_header "ALAWAEL Full System Quality Check"
            echo ""
            echo -e "${CYAN}Running comprehensive system quality validation...${RESET}"
            echo "This may take up to 60 minutes"
            echo ""

            echo "Session Start: $(date +%Y-%m-%d\ %H:%M:%S)" > "$REPORT_FILE"
            echo "" >> "$REPORT_FILE"

            ./quality all

            generate_summary_report
            show_recommendations
            ;;

        service)
            local service=${2:-backend}
            print_header "ALAWAEL Service Quality Check: $service"
            echo ""
            ./quality "$service"
            ;;

        monitor)
            print_header "ALAWAEL Performance Monitoring"
            echo ""
            ./scripts/quality-performance-monitor.sh
            ;;

        coverage)
            print_header "ALAWAEL Coverage Analysis"
            echo ""
            ./scripts/coverage-analyzer.sh
            ;;

        report)
            print_header "ALAWAEL Quality Reports"
            echo ""
            echo -e "${CYAN}Available Quality Reports:${RESET}"
            ls -lh "${REPORT_DIR}"/report_*.txt 2>/dev/null | tail -10 | awk '{print $9, "(" $5 ")"}'
            echo ""
            if [ -f "${REPORT_DIR}/report_latest.txt" ]; then
                echo -e "${CYAN}Latest Report:${RESET}"
                cat "${REPORT_DIR}/report_latest.txt"
            fi
            ;;

        help|--help|-h|'')
            cat << 'HELP'

╔════════════════════════════════════════════════════════════════╗
║     ALAWAEL Enhanced Quality Control System (Quality+)         ║
║            Advanced Mode with Monitoring                       ║
║        Phase 4A: Extended to 10 Services Monitoring            ║
╚════════════════════════════════════════════════════════════════╝

USAGE:
  ./quality+ <mode> [options]

MODES:

  quick                Run fast smoke tests (~20 min)
                       └─ Backend phase2 + Phase4A service guards
                       └─ Best for: Feature branch validation

  full                 Run complete system validation (~90 min)
                       └─ All 10 services in sequence
                       └─ Includes: Phase 2 (5) + Phase 4A (5) services
                       └─ Best for: Before release, major merge

  service <name>       Run single service quality check
                       └─ Phase 2: backend, graphql, finance, supply-chain, frontend
                       └─ Phase 4A: intelligent-agent, mobile, gateway, whatsapp, backend-1
                       └─ Best for: Debugging specific service issues

  monitor              Analyze quality check performance
                       └─ Measures execution times across all 10 services
                       └─ Tracks performance trends
                       └─ Best for: Performance optimization

  coverage             Analyze test coverage across services
                       └─ Aggregates coverage metrics for all services
                       └─ Shows coverage gaps
                       └─ Best for: Coverage reporting

  report               View quality reports history
                       └─ Lists recent quality checks
                       └─ Shows detailed results
                       └─ Best for: Post-incident analysis

  help                 Show this help message

EXAMPLES:

  # Quick feedback before push (Phase 4A ready)
  ./quality+ quick

  # Full validation before release (10 services)
  ./quality+ full

  # Debug Intelligent Agent issues
  ./quality+ service intelligent-agent

  # Test new mobile service
  ./quality+ service mobile

  # Monitor all service performance
  ./quality+ monitor

  # Check coverage across system
  ./quality+ coverage

INTEGRATION:

  ✓ GitHub Actions:  Automatically runs appropriate quality mode
  ✓ Local CLI:       Use this for manual quality management
  ✓ CI/CD:          Parallel execution in workflows
  ✓ Phase 4A:       Extended to 10 services (100% coverage)
  ✓ Reporting:      Detailed reports saved locally

PERFORMANCE GUIDE:

  Mode        │ Duration  │ Scope                        │ Use When
  ────────────┼───────────┼──────────────────────────────┼──────────────────────
  quick       │ ~20 min   │ Phase2 + Phase4A guards      │ Before git push
  service     │ ~5 min    │ Single service               │ Debugging issues
  full        │ ~90 min   │ All 10 services (seq)        │ Before release
  monitor     │ Variable  │ Performance analysis         │ Tracking metrics
  coverage    │ ~5 min    │ Coverage analysis            │ Coverage reporting

SERVICES AVAILABLE IN PHASE 4A:

  Phase 2 (5 services - Original):
    - Backend (894 tests, ~35 min)
    - GraphQL (~5 min)
    - Finance (~5 min)
    - Supply Chain Backend (~5 min)
    - Frontend (~5 min)

  Phase 4A NEW (5 services - Extended):
    - Intelligent Agent (TypeScript/Vitest, ~5 min)
    - Mobile (React Native/Jest, ~5 min)
    - Gateway (Express/Jest, ~5 min)
    - WhatsApp (Express/Jest, ~5 min)
    - Backend-1 (Legacy, ~1 min)

ADVANCED OPTIONS:

  Environment Variables:
    VERBOSE=true ./quality+ quick     # Detailed output
    PARALLEL=true ./quality+ full     # Force parallel (if available)
    TIMEOUT=120 ./quality+ service    # Custom timeout (seconds)

TROUBLESHOOTING:

  Issue:           Solution:
  ────────────────────────────────────────────────────────
  Module not found Execute: npm install in affected service
  Permission denied Execute: chmod +x ./quality+
  Timeout          Check: ./quality+ monitor for slow tests
  Coverage missing Execute: npm test -- --coverage in service

For detailed documentation:
  - Quick Start:     cat QUICKSTART_QUALITY.md
  - Full Guide:      cat SYSTEM_QUALITY_GUIDE.md
  - Phase 4 Plan:    cat PHASE4_EXECUTION_PLAN.md
  - Phase Report:    cat PHASE2_QUALITY_EXPANSION_COMPLETE.md

HELP
            ;;

        *)
            print_error "Unknown mode: $mode"
            echo "Use './quality+ help' for usage information"
            exit 1
            ;;
    esac
}

main "$@"
