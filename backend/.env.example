# ═══════════════════════════════════════════════════════════════════════════════
# Al-Awael ERP — Environment Configuration
# Copy to .env and fill in your values. Commented vars are optional.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
# SERVICE_NAME=alawael-erp
# SERVICE_VERSION=1.0.0
# HOSTNAME=localhost
# WORKER_COUNT=0
# CLUSTER_ENABLED=false
# CLUSTER_WORKERS=0

# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/alawael-erp
USE_MOCK_DB=false
# MONGODB_ATLAS_URI=
# MONGODB_TEST_URI=mongodb://localhost:27017/alawael-erp-test
# MONGODB_MAX_POOL_SIZE=50
# MONGODB_REPLICA_SET=
# MONGODB_DATABASE=alawael-erp
# MONGODB_USERNAME=
# MONGODB_PASSWORD=
# DB_POOL_SIZE=10
# DB_MAX_RETRIES=3
# DB_INITIAL_RETRY_DELAY=1000
# DB_MAX_RETRY_DELAY=30000
# DB_BACKOFF_MULTIPLIER=2
# DB_TLS=false
# DATABASE_TIMEOUT=30000
# MONGOOSE_BUFFER_TIMEOUT=30000
# SLOW_QUERY_MS=100

# ─── Authentication & JWT ────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-min-16-chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=change-me-different-random-string-min-32-chars
JWT_ACCESS_EXPIRY=15m
# JWT_REFRESH_EXPIRY=7d
# JWT_ISSUER=alawael-erp
# JWT_AUDIENCE=alawael-erp-api
# SESSION_SECRET=change-me-session-secret
# SESSION_TIMEOUT=3600
# MFA_ENABLED=false
# MAX_LOGIN_ATTEMPTS=5
# LOGIN_ATTEMPT_WINDOW=900000
# REFRESH_TOKEN_EXPIRES_IN=7d

# ─── OTP Configuration ──────────────────────────────────────────────────────
# OTP_LENGTH=6
# OTP_EXPIRY_SECONDS=300
# OTP_MAX_ATTEMPTS=3
# OTP_RESEND_COOLDOWN=60
# OTP_EMAIL_ENABLED=true
# OTP_SMS_ENABLED=false
# OTP_WHATSAPP_ENABLED=false

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
DISABLE_REDIS=false
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_ENABLED=true
# USE_MOCK_CACHE=false
# CACHE_TTL=3600

# ─── CORS & Security ────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# CORS_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# BACKEND_URL=http://localhost:3001
# API_BASE_URL=http://localhost:3001/api
# CSRF_DISABLE=false
# CSRF_EXCLUDE_PATHS=/api/webhooks
# SECURITY_HEADERS_ENABLED=true
# SANITIZE_INPUT=true
# SKIP_RATE_LIMIT=false
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
# SUSPICIOUS_ACTIVITY_THRESHOLD=10
# DATA_ENCRYPTION_KEY=
# ENCRYPTION_KEY=
# HMAC_KEY=

# ─── Logging & Monitoring ───────────────────────────────────────────────────
