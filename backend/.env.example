# ═══════════════════════════════════════════════════════════════
# Al-Awael ERP — Backend Environment Variables
# Copy this file to .env and fill in real values
# ⚠️  NEVER commit .env files to version control!
# ═══════════════════════════════════════════════════════════════

# ─── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/alawael-erp
# USE_MOCK_DB=true  # Uncomment for in-memory DB (no MongoDB needed)

# ─── Authentication ──────────────────────────────────────────
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ─── Admin Setup (used by /api/_init endpoint) ───────────────
SETUP_SECRET_KEY=CHANGE_ME_random_secret_key
ADMIN_EMAIL=admin@alawael.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
# ALLOW_ADMIN_INIT=true  # Only enable when needed, disable after

# ─── Redis (optional — disabled by default) ──────────────────
# REDIS_URL=redis://localhost:6379
# DISABLE_REDIS=true

# ─── CORS ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# CORS_ORIGINS=http://localhost:3000,http://localhost:3004

# ─── Email System (Unified) ──────────────────────────────────
# EMAIL_ENABLED=true
# EMAIL_PROVIDER=smtp                    # smtp | sendgrid | mailgun | azure
#
# SMTP / Nodemailer
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password        # (or SMTP_PASS)
# SMTP_MAX_CONNECTIONS=5
# SMTP_MAX_MESSAGES=100
#
# SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=noreply@alawael-erp.com
# SENDGRID_WEBHOOK_PUBLIC_KEY=
#
# Mailgun (optional)
# MAILGUN_API_KEY=key-xxxxxxxxxxxx
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_FROM_EMAIL=noreply@yourdomain.com
#
# Azure Communication Services (optional)
# AZURE_COMMUNICATION_CONNECTION_STRING=
# AZURE_SENDER_ADDRESS=
# AZURE_WEBHOOK_SECRET=
#
# Sender Defaults
# EMAIL_FROM=noreply@alawael-erp.com
# EMAIL_FROM_NAME=نظام الأوائل ERP
# EMAIL_REPLY_TO=support@alawael-erp.com
#
# Rate Limiting
# EMAIL_RATE_PER_MINUTE=30
# EMAIL_RATE_PER_HOUR=500
# EMAIL_RATE_PER_DAY=5000
#
# Queue & Retry
# EMAIL_RETRY_MAX=3
# EMAIL_RETRY_DELAY=5000
# EMAIL_QUEUE_BATCH=10
# EMAIL_QUEUE_INTERVAL=30000
#
# Tracking & Logging
# EMAIL_TRACK_OPENS=true
# EMAIL_TRACK_CLICKS=true
# EMAIL_TRACKING_URL=https://yourdomain.com/api/v2/email
# EMAIL_LOG_TO_DB=true
# EMAIL_LOG_LEVEL=info
# EMAIL_LOG_RETAIN_DAYS=90
#
# Branding
# COMPANY_NAME=مركز الأوائل للتأهيل
# COMPANY_NAME_EN=Al-Awael Rehabilitation Center
# COMPANY_LOGO_URL=
# BRAND_PRIMARY_COLOR=#667eea
# BRAND_SECONDARY_COLOR=#764ba2
#
# Integration Email Addresses (for cross-system notifications)
# HR_MANAGER_EMAIL=hr@alawael-erp.com
# FINANCE_MANAGER_EMAIL=finance@alawael-erp.com
# CARE_TEAM_EMAIL=care@alawael-erp.com
# ADMIN_ALERT_EMAIL=admin@alawael-erp.com
# SYSTEM_ADMIN_EMAIL=sysadmin@alawael-erp.com
#
# Work Schedule (for attendance alerts)
# WORK_START_HOUR=8
#
# Finance Thresholds
# LARGE_TRANSACTION_THRESHOLD=50000

# ─── SMS (Twilio) ───────────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# ─── File Upload Limits ─────────────────────────────────────
FILE_SIZE_LIMIT_MB=50

# ─── File Storage (AWS S3) ──────────────────────────────────
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=me-south-1
# S3_BUCKET=alawael-uploads

# ─── Payments ───────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ─── Observability ──────────────────────────────────────────
# METRICS_TOKEN=your_metrics_bearer_token
# SENTRY_DSN=https://xxxxxxxx@sentry.io/xxxxxxxx
LOG_LEVEL=info

# ─── Feature Flags ──────────────────────────────────────────
# ENABLE_SWAGGER=true
# CSRF_DISABLE=false

# ═══════════════════════════════════════════════════════════════════════
#  Saudi gov-integration adapters (shipped in 4.0.0 – 4.0.4)
#
#  Every adapter defaults to `mock` so dev/staging/CI run credential-free.
#  Flipping to `live` requires:
#    1. The business contract signed (see docs/sprints/GOV_INTEGRATIONS_GO_LIVE.md)
#    2. Every {PROVIDER}_* variable below populated
#    3. `{PROVIDER}_MODE=live`
#    4. A sanity check via POST /admin/gov-integrations/:provider/test-connection
#
#  The common knobs (timeout / circuit-breaker / rate-limit) apply to
#  every adapter — same variable pattern, different prefix. Only the
#  paid adapters (GOSI, Absher, NPHIES, Fatoora) register a circuit
#  breaker; the other 6 just respect the rate limiter.
# ═══════════════════════════════════════════════════════════════════════

# ─── GOSI (التأمينات الاجتماعية) ──────────────────────────
# GOSI_MODE=mock            # mock | live (default mock)
# GOSI_BASE_URL=https://api.gosi.gov.sa
# GOSI_CLIENT_ID=...
# GOSI_CLIENT_SECRET=...
# GOSI_TIMEOUT_MS=8000      # request timeout (default 8s)
# GOSI_MAX_FAILURES=5       # circuit trip threshold (default 5)
# GOSI_COOLDOWN_MS=120000   # circuit open duration (default 120s)
# GOSI_RL_CAPACITY=60       # token-bucket capacity (default 60)
# GOSI_RL_REFILL_PER_MIN=30 # refill rate (default 30/min)
# GOSI_RL_ACTOR_CAP=20      # per-actor cap within pool (default 20)

# ─── SCFHS (الهيئة السعودية للتخصصات الصحية) ──────────────
# SCFHS_MODE=mock
# SCFHS_BASE_URL=...
# SCFHS_API_KEY=...

# ─── Absher / Yakeen (الأحوال المدنية) ────────────────────
# ABSHER_MODE=mock
# ABSHER_BASE_URL=https://api.absher.sa
# ABSHER_CLIENT_ID=...
# ABSHER_CLIENT_SECRET=...
# ABSHER_RL_CAPACITY=30     # tight — Absher bills per call
# ABSHER_RL_REFILL_PER_MIN=10
# ABSHER_RL_ACTOR_CAP=5

# ─── Qiwa (قوى — وزارة الموارد البشرية) ───────────────────
# QIWA_MODE=mock
# QIWA_BASE_URL=https://api.qiwa.sa
# QIWA_CLIENT_ID=...
# QIWA_CLIENT_SECRET=...
# QIWA_ESTABLISHMENT_ID=...

# ─── Nafath (نفاذ — SSO) ───────────────────────────────────
# NAFATH_MODE=mock
# NAFATH_BASE_URL=...
# NAFATH_APP_ID=...
# NAFATH_SERVICE_ID=...
# NAFATH_PRIVATE_KEY=...    # store via secret manager, not .env

# ─── Fatoora / ZATCA (فاتورة) ─────────────────────────────
# Two-stage: signer + submission. Signer needs the CSR-issued CSID.
# ZATCA_SIGNER_MODE=mock
# ZATCA_PRIVATE_KEY=...     # PEM 2048-bit RSA
# ZATCA_CSID_CERT=...       # base64 DER — production CSID
# ZATCA_SELLER_NAME=...
# ZATCA_SELLER_VAT=...
# ZATCA_SELLER_CR=...
# FATOORA_MODE=mock
# FATOORA_BASE_URL=https://gw-fatoora.zatca.gov.sa/e-invoicing/core
# FATOORA_BINARY_TOKEN=...  # base64 for Basic auth
# FATOORA_MODE_TYPE=reporting  # or 'clearance' for B2B above threshold
# FATOORA_TIMEOUT_MS=12000
# FATOORA_RL_CAPACITY=600   # ZATCA allows ~10/s so bucket is generous
# FATOORA_RL_REFILL_PER_MIN=600
# FATOORA_RL_ACTOR_CAP=200

# ─── Muqeem (مقيم — إدارة الإقامات) ───────────────────────
# MUQEEM_MODE=mock
# MUQEEM_BASE_URL=https://api.muqeem.sa
# MUQEEM_CLIENT_ID=...
# MUQEEM_CLIENT_SECRET=...
# MUQEEM_ESTABLISHMENT_ID=...

# ─── NPHIES / CCHI (التأمين الصحي التعاوني) ──────────────
# NPHIES_MODE=mock
# NPHIES_BASE_URL=...
# NPHIES_CLIENT_ID=...
# NPHIES_CLIENT_SECRET=...
# NPHIES_PROVIDER_ID=...    # your CCHI-issued HPO license
# NPHIES_RL_CAPACITY=120    # bulk claim friendly
# NPHIES_RL_REFILL_PER_MIN=60
# NPHIES_RL_ACTOR_CAP=30

# ─── Wasel / SPL (واصل — عناوين البريد السعودي) ──────────
# WASEL_MODE=mock
# WASEL_BASE_URL=https://api.address.gov.sa
# WASEL_API_KEY=...
# WASEL_TEST_CODE=RFYA1234  # known-valid short code for test-connection

# ─── Balady (بلدي — تراخيص البلديات) ─────────────────────
# BALADY_MODE=mock
# BALADY_BASE_URL=...
# BALADY_CLIENT_ID=...
# BALADY_CLIENT_SECRET=...
# PHASE2933_PUBLIC=false
