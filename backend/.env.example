# ═══════════════════════════════════════════════════════════════
# Al-Awael ERP — Backend Environment Variables
# Copy this file to .env and fill in real values
# ⚠️  NEVER commit .env files to version control!
# ═══════════════════════════════════════════════════════════════

# ─── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/alawael-erp
# USE_MOCK_DB=true  # Uncomment for in-memory DB (no MongoDB needed)

# ─── Authentication ──────────────────────────────────────────
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ─── Admin Setup (used by /api/_init endpoint) ───────────────
SETUP_SECRET_KEY=CHANGE_ME_random_secret_key
ADMIN_EMAIL=admin@alawael.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
# ALLOW_ADMIN_INIT=true  # Only enable when needed, disable after

# ─── Redis (optional — disabled by default) ──────────────────
# REDIS_URL=redis://localhost:6379
# DISABLE_REDIS=true

# ─── CORS ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# CORS_ORIGINS=http://localhost:3000,http://localhost:3004

# ─── Email System (Unified) ──────────────────────────────────
# EMAIL_ENABLED=true
# EMAIL_PROVIDER=smtp                    # smtp | sendgrid | mailgun | azure
#
# SMTP / Nodemailer
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password        # (or SMTP_PASS)
# SMTP_MAX_CONNECTIONS=5
# SMTP_MAX_MESSAGES=100
#
# SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=noreply@alawael-erp.com
# SENDGRID_WEBHOOK_PUBLIC_KEY=
#
# Mailgun (optional)
# MAILGUN_API_KEY=key-xxxxxxxxxxxx
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_FROM_EMAIL=noreply@yourdomain.com
#
# Azure Communication Services (optional)
# AZURE_COMMUNICATION_CONNECTION_STRING=
# AZURE_SENDER_ADDRESS=
# AZURE_WEBHOOK_SECRET=
#
# Sender Defaults
# EMAIL_FROM=noreply@alawael-erp.com
# EMAIL_FROM_NAME=نظام الأوائل ERP
# EMAIL_REPLY_TO=support@alawael-erp.com
#
# Rate Limiting
# EMAIL_RATE_PER_MINUTE=30
# EMAIL_RATE_PER_HOUR=500
# EMAIL_RATE_PER_DAY=5000
#
# Queue & Retry
# EMAIL_RETRY_MAX=3
# EMAIL_RETRY_DELAY=5000
# EMAIL_QUEUE_BATCH=10
# EMAIL_QUEUE_INTERVAL=30000
#
# Tracking & Logging
# EMAIL_TRACK_OPENS=true
# EMAIL_TRACK_CLICKS=true
# EMAIL_TRACKING_URL=https://yourdomain.com/api/v2/email
# EMAIL_LOG_TO_DB=true
# EMAIL_LOG_LEVEL=info
# EMAIL_LOG_RETAIN_DAYS=90
#
# Branding
# COMPANY_NAME=مركز الأوائل للتأهيل
# COMPANY_NAME_EN=Al-Awael Rehabilitation Center
# COMPANY_LOGO_URL=
# BRAND_PRIMARY_COLOR=#667eea
# BRAND_SECONDARY_COLOR=#764ba2
#
# Integration Email Addresses (for cross-system notifications)
# HR_MANAGER_EMAIL=hr@alawael-erp.com
# FINANCE_MANAGER_EMAIL=finance@alawael-erp.com
# CARE_TEAM_EMAIL=care@alawael-erp.com
# ADMIN_ALERT_EMAIL=admin@alawael-erp.com
# SYSTEM_ADMIN_EMAIL=sysadmin@alawael-erp.com
#
# Work Schedule (for attendance alerts)
# WORK_START_HOUR=8
#
# Finance Thresholds
# LARGE_TRANSACTION_THRESHOLD=50000

# ─── SMS (Twilio) ───────────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# ─── File Storage (AWS S3) ──────────────────────────────────
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=me-south-1
# S3_BUCKET=alawael-uploads

# ─── Payments ───────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ─── Observability ──────────────────────────────────────────
# METRICS_TOKEN=your_metrics_bearer_token
# SENTRY_DSN=https://xxxxxxxx@sentry.io/xxxxxxxx
LOG_LEVEL=info

# ─── Feature Flags ──────────────────────────────────────────
# ENABLE_SWAGGER=true
# CSRF_DISABLE=false
# PHASE2933_PUBLIC=false
