# ═══════════════════════════════════════════════════════════════
# Al-Awael ERP — Backend Environment Variables
# Copy this file to .env and fill in real values
# ⚠️  NEVER commit .env files to version control!
#
# 📖 Setup Guide: docs/runbooks/environment-setup.md
#    Minimal bootstrap: backend/.env.minimum.example
#    Full features:     backend/.env.example (this file)
# ═══════════════════════════════════════════════════════════════

# ─── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/alawael-erp
# MONGO_TIMEOUT_MS=30000   # MongoDB operation timeout in milliseconds
# USE_MOCK_DB=true  # Uncomment for in-memory DB (no MongoDB needed)

# ─── Authentication ──────────────────────────────────────────
# Strict-required (config/validateEnv.js): JWT_SECRET signs access tokens,
# JWT_REFRESH_SECRET signs refresh tokens. Both min 32 chars — keep DISTINCT.
# Generate each: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ─── Smart Transport (Parent tracking, HMAC-signed 6h token) ─
# MUST be rotated before issuing tracking tokens to parents.
TRANSPORT_TRACKING_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64

# Public origin used when embedding the tracking link in WhatsApp/SMS
# (defaults to a path-only URL when unset, which only works on same-origin).
# Example: https://alaweal.org
PUBLIC_BASE_URL=

# WhatsApp Cloud API (optional — without these the notifier falls back
# to wa.me share links and SMS/email channels).
WA_TOKEN=
WA_PHONE_NUMBER_ID=

# ─── Admin Setup (used by /api/_init endpoint) ───────────────
SETUP_SECRET_KEY=CHANGE_ME_random_secret_key
ADMIN_EMAIL=admin@alawael.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
# ALLOW_ADMIN_INIT=true  # Only enable when needed, disable after

# ─── WhatsApp Integration ─────────────────────────────────────
# Enable the full WhatsApp system (Phase 1–5)
WHATSAPP_ENABLED=false
WHATSAPP_PRIMARY_PROVIDER=ultramsg
WHATSAPP_FALLBACK_PROVIDER=twilio
WHATSAPP_WEBHOOK_SECRET=CHANGE_ME_webhook_secret_for_signature_verification
WHATSAPP_WEBHOOK_URL=https://api.alaweal.org/webhooks/whatsapp

# UltraMsg (Primary Saudi-friendly provider)
# Get from: https://ultramsg.com/
ULTRAMSG_INSTANCE_ID=your_instance_id
ULTRAMSG_TOKEN=your_ultramsg_token

# Twilio WhatsApp (Fallback)
# Get from: https://www.twilio.com/console
TWILIO_WHATSAPP_SID=your_twilio_account_sid
TWILIO_WHATSAPP_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# WhatsApp Queue (BullMQ on Redis)
WHATSAPP_QUEUE_ENABLED=true
WHATSAPP_QUEUE_CONCURRENCY=5
WHATSAPP_QUEUE_RATE_LIMIT=30
WHATSAPP_RATE_LIMIT_PER_SEC=30
WHATSAPP_RATE_LIMIT_PER_MIN=300
WHATSAPP_RATE_LIMIT_PER_HOUR=1000

# WhatsApp Chatbot
WHATSAPP_CHATBOT_ENABLED=true
WHATSAPP_CHATBOT_FALLBACK_HUMAN=true
WHATSAPP_CHATBOT_EMERGENCY_KEYWORDS=طوارئ,أزمة,مساعدة,مستعجل,urgent,emergency

# WhatsApp Templates
WHATSAPP_TEMPLATES_NAMESPACE=alawael
WHATSAPP_TEMPLATES_LANGUAGE=ar

# ─── Redis (optional — disabled by default) ──────────────────
# REDIS_URL=redis://localhost:6379
# DISABLE_REDIS=true

# ─── CORS ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# CORS_ORIGINS=http://localhost:3000,http://localhost:3004

# ─── Email System (Unified) ──────────────────────────────────
# EMAIL_ENABLED=true
# EMAIL_PROVIDER=smtp                    # smtp | sendgrid | mailgun | azure
#
# SMTP / Nodemailer
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password        # (or SMTP_PASSWORD)
# SMTP_MAX_CONNECTIONS=5
# SMTP_MAX_MESSAGES=100
#
# SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=noreply@alawael-erp.com
# SENDGRID_WEBHOOK_PUBLIC_KEY=
#
# Mailgun (optional)
# MAILGUN_API_KEY=key-xxxxxxxxxxxx
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_FROM_EMAIL=noreply@yourdomain.com
#
# Azure Communication Services (optional)
# AZURE_COMMUNICATION_CONNECTION_STRING=
# AZURE_SENDER_ADDRESS=
# AZURE_WEBHOOK_SECRET=
#
# Sender Defaults
# EMAIL_FROM=noreply@alawael-erp.com
# EMAIL_FROM_NAME=نظام الأوائل ERP
# EMAIL_REPLY_TO=support@alawael-erp.com
#
# Rate Limiting
# EMAIL_RATE_PER_MINUTE=30
# EMAIL_RATE_PER_HOUR=500
# EMAIL_RATE_PER_DAY=5000
#
# Queue & Retry
# EMAIL_RETRY_MAX=3
# EMAIL_RETRY_DELAY=5000
# EMAIL_QUEUE_BATCH=10
# EMAIL_QUEUE_INTERVAL=30000
#
# Tracking & Logging
# EMAIL_TRACK_OPENS=true
# EMAIL_TRACK_CLICKS=true
# EMAIL_TRACKING_URL=https://yourdomain.com/api/v2/email
# EMAIL_LOG_TO_DB=true
# EMAIL_LOG_LEVEL=info
# EMAIL_LOG_RETAIN_DAYS=90
#
# Branding
# COMPANY_NAME=مركز الأوائل للتأهيل
# COMPANY_NAME_EN=Al-Awael Rehabilitation Center
# COMPANY_LOGO_URL=
# BRAND_PRIMARY_COLOR=#667eea
# BRAND_SECONDARY_COLOR=#764ba2
#
# Integration Email Addresses (for cross-system notifications)
# HR_MANAGER_EMAIL=hr@alawael-erp.com
# FINANCE_MANAGER_EMAIL=finance@alawael-erp.com
# CARE_TEAM_EMAIL=care@alawael-erp.com
# ADMIN_ALERT_EMAIL=admin@alawael-erp.com
# SYSTEM_ADMIN_EMAIL=sysadmin@alawael-erp.com
#
# Work Schedule (for attendance alerts)
# WORK_START_HOUR=8
#
# Finance Thresholds
# LARGE_TRANSACTION_THRESHOLD=50000

# ─── SMS (Twilio) ───────────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# ─── File Upload Limits ─────────────────────────────────────
FILE_SIZE_LIMIT_MB=50

# ─── File Storage (AWS S3) ──────────────────────────────────
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=me-south-1
# S3_BUCKET=alawael-uploads

# ─── Speech retention sweeper (PDPL gate — W284c/W284d) ─────
# REQUIRED for real S3 audio purger to activate. Without these,
# ENABLE_SPEECH_RETENTION_CRON=true falls back to log-only (no PDPL).
# Verify with: npm run check:speech-s3-ready
# AWS_REGION=me-south-1              # required (uncomment & set)
# SPEECH_S3_BUCKET=alawael-speech    # bucket for SpeechSessionRecording audio
# ENABLE_SPEECH_RETENTION_CRON=false # flip to true ONLY after check passes

# ─── Payments ───────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ─── Observability ──────────────────────────────────────────
# METRICS_TOKEN=your_metrics_bearer_token
# SENTRY_DSN=https://xxxxxxxx@sentry.io/xxxxxxxx
LOG_LEVEL=info

# ─── Feature Flags ──────────────────────────────────────────
# ENABLE_SWAGGER=true
# CSRF_DISABLE=false

# ═══════════════════════════════════════════════════════════════════════
#  Saudi gov-integration adapters (shipped in 4.0.0 – 4.0.4)
#
#  Every adapter defaults to `mock` so dev/staging/CI run credential-free.
#  Flipping to `live` requires:
#    1. The business contract signed (see docs/sprints/GOV_INTEGRATIONS_GO_LIVE.md)
#    2. Every {PROVIDER}_* variable below populated
#    3. `{PROVIDER}_MODE=live`
#    4. A sanity check via POST /admin/gov-integrations/:provider/test-connection
#
#  The common knobs (timeout / circuit-breaker / rate-limit) apply to
#  every adapter — same variable pattern, different prefix. Only the
#  paid adapters (GOSI, Absher, NPHIES, Fatoora) register a circuit
#  breaker; the other 6 just respect the rate limiter.
#
#  Legacy unified variables (used by older gosi-advanced.service & qiwa.service):
#    SAUDI_GOV_API_URL=...
#    SAUDI_GOV_API_KEY=...
#    SAUDI_GOV_CERT_PATH=...
#    SAUDI_GOV_KEY_PATH=...
# ═══════════════════════════════════════════════════════════════════════

# ─── GOSI (التأمينات الاجتماعية) ──────────────────────────
# GOSI_MODE=mock            # mock | live (default mock)
# GOSI_BASE_URL=https://api.gosi.gov.sa
# GOSI_CLIENT_ID=...
# GOSI_CLIENT_SECRET=...
# GOSI_API_BASE_URL=https://api.gosi.gov.sa      # legacy alias for gosi-advanced.service
# GOSI_API_KEY=...                                 # legacy API key for gosi-advanced.service
# USE_MOCK_GOSI=true                               # fallback mock mode for gosi-advanced.service
# GOSI_TIMEOUT_MS=8000      # request timeout (default 8s)
# GOSI_MAX_FAILURES=5       # circuit trip threshold (default 5)
# GOSI_COOLDOWN_MS=120000   # circuit open duration (default 120s)
# GOSI_RL_CAPACITY=60       # token-bucket capacity (default 60)
# GOSI_RL_REFILL_PER_MIN=30 # refill rate (default 30/min)
# GOSI_RL_ACTOR_CAP=20      # per-actor cap within pool (default 20)

# ─── SCFHS (الهيئة السعودية للتخصصات الصحية) ──────────────
# SCFHS_MODE=mock
# SCFHS_BASE_URL=...
# SCFHS_API_KEY=...

# ─── Absher / Yakeen (الأحوال المدنية) ────────────────────
# ABSHER_MODE=mock
# ABSHER_BASE_URL=https://api.absher.sa
# ABSHER_CLIENT_ID=...
# ABSHER_CLIENT_SECRET=...
# ABSHER_RL_CAPACITY=30     # tight — Absher bills per call
# ABSHER_RL_REFILL_PER_MIN=10
# ABSHER_RL_ACTOR_CAP=5

# ─── Qiwa (قوى — وزارة الموارد البشرية) ───────────────────
# QIWA_MODE=mock
# QIWA_BASE_URL=https://api.qiwa.sa
# QIWA_CLIENT_ID=...
# QIWA_CLIENT_SECRET=...
# QIWA_ESTABLISHMENT_ID=...
# QIWA_API_BASE_URL=https://api.qiwa.sa/v1    # legacy alias for qiwa.service
# QIWA_API_KEY=...                             # legacy API key for qiwa.service
# QIWA_API_SECRET=...                          # legacy API secret for qiwa.service
# QIWA_LABOR_OFFICE_ID=...                     # legacy labor office ID for qiwa.service

# ─── Nafath (نفاذ — SSO) ───────────────────────────────────
# NAFATH_MODE=mock
# NAFATH_BASE_URL=...
# NAFATH_APP_ID=...
# NAFATH_SERVICE_ID=...
# NAFATH_PRIVATE_KEY=...    # store via secret manager, not .env

# ─── Fatoora / ZATCA (فاتورة) ─────────────────────────────
# Two-stage: signer + submission. Signer needs the CSR-issued CSID.
# ZATCA_SIGNER_MODE=mock
# ZATCA_PRIVATE_KEY=...     # PEM 2048-bit RSA
# ZATCA_CSID_CERT=...       # base64 DER — production CSID
# ZATCA_SELLER_NAME=...
# ZATCA_SELLER_VAT=...
# ZATCA_SELLER_CR=...
# FATOORA_MODE=mock
# FATOORA_BASE_URL=https://gw-fatoora.zatca.gov.sa/e-invoicing/core
# FATOORA_BINARY_TOKEN=...  # base64 for Basic auth
# FATOORA_MODE_TYPE=reporting  # or 'clearance' for B2B above threshold
# FATOORA_TIMEOUT_MS=12000
# FATOORA_RL_CAPACITY=600   # ZATCA allows ~10/s so bucket is generous
# FATOORA_RL_REFILL_PER_MIN=600
# FATOORA_RL_ACTOR_CAP=200

# ─── Muqeem (مقيم — إدارة الإقامات) ───────────────────────
# MUQEEM_MODE=mock
# MUQEEM_BASE_URL=https://api.muqeem.sa
# MUQEEM_CLIENT_ID=...
# MUQEEM_CLIENT_SECRET=...
# MUQEEM_ESTABLISHMENT_ID=...

# ─── NPHIES / CCHI (التأمين الصحي التعاوني) ──────────────
# NPHIES_MODE=mock
# NPHIES_BASE_URL=...
# NPHIES_CLIENT_ID=...
# NPHIES_CLIENT_SECRET=...
# NPHIES_PROVIDER_ID=...    # your CCHI-issued HPO license
# NPHIES_RL_CAPACITY=120    # bulk claim friendly
# NPHIES_RL_REFILL_PER_MIN=60
# NPHIES_RL_ACTOR_CAP=30

# ─── Wasel / SPL (واصل — عناوين البريد السعودي) ──────────
# WASEL_MODE=mock
# WASEL_BASE_URL=https://api.address.gov.sa
# WASEL_API_KEY=...

# ─── Universal Code ──────────────────────────────────────────
# 2-3 character organisational prefix used when generating universal/
# cross-module codes (e.g. "RH" for rehabilitation, "SC" for supply-chain).
# Defaults to "RH" if unset.
UNIVERSAL_CODE_PREFIX=RH
# WASEL_TEST_CODE=RFYA1234  # known-valid short code for test-connection

# ─── Balady (بلدي — تراخيص البلديات) ─────────────────────
# BALADY_MODE=mock
# BALADY_BASE_URL=...
# BALADY_CLIENT_ID=...
# BALADY_CLIENT_SECRET=...

# ─── WhatsApp Business API (Meta Cloud API v21.0) ────────────
# Required when going beyond stub mode. All inbound webhook events from
# Meta are HMAC-signed; without WHATSAPP_WEBHOOK_SECRET the webhook
# defaults to "warn + accept" — set this in production.
# WHATSAPP_ENABLED=true                # forces enabled even without token
# WHATSAPP_API_TOKEN=EAAxxxx            # Meta system-user permanent token
# WHATSAPP_PHONE_ID=1234567890          # phone-number-id from Meta dashboard
# WHATSAPP_BUSINESS_ID=...              # Meta WhatsApp Business Account ID
# WHATSAPP_WEBHOOK_SECRET=<random>      # Meta "App Secret" for X-Hub HMAC
# WHATSAPP_VERIFY_TOKEN=<random>        # value Meta sends in GET /webhook?hub.verify_token
# WHATSAPP_TEMPLATE_NAMESPACE=          # optional, for namespaced templates
# ENABLE_WHATSAPP_BOT_MENU=true         # W1372: stateful menu-bot on inbound
#   When set, a deterministic FSM drives inbound replies — a welcome menu (with
#   bot-identity disclosure) + 10 multi-step flows (registration / appointment /
#   complaint / human callback / read-only lookups). Runs BEFORE the stateless
#   auto-reply classifier and short-circuits it when it handles a turn. Default
#   OFF: existing auto-reply behavior is unchanged until you opt in.
# ENABLE_WHATSAPP_BOT_LIVE_DATA=true     # W1372 Wave 2: guardian-verified live data
#   Requires ENABLE_WHATSAPP_BOT_MENU. When set, the attendance / session-report
#   / billing menu units return REAL data instead of escalating — but ONLY for a
#   beneficiary the inbound phone is a registered AUTHORIZED guardian of
#   (portalAccess.enabled / isLegalGuardian / isPrimaryContact). It never looks a
#   beneficiary up by typed name; if the phone is unverified or the child is
#   ambiguous, it falls back to staff escalation. Default OFF — sensitive
#   clinical/financial data is never auto-sent until you explicitly opt in.
# ENABLE_WHATSAPP_BOT_INTERACTIVE=true   # W1381: native interactive menu
#   Requires ENABLE_WHATSAPP_BOT_MENU. When set, the main menu is sent as a
#   tappable WhatsApp list (categories → sub-lists) instead of numbered text.
#   Default OFF: the numbered-text menu remains the fallback for old clients.
# ENABLE_WHATSAPP_BOT_RECORDS=true       # W1384: requests → real DB records
#   Requires ENABLE_WHATSAPP_BOT_MENU. When set, completed flows create real
#   trackable records: complaint→Complaint, satisfaction→NpsResponse (needs a
#   linked guardian), registration→PublicBookingRequest. Staff are still
#   notified (with the record id). Default OFF: flows escalate only.
# ENABLE_WHATSAPP_BOT_INSIGHTS=true      # W1417: capture unmatched free-text
#   intents the bot couldn't route, aggregated (normalized phrase + count, 30-day
#   TTL). Admins review GET /api/whatsapp/bot/unmatched-intents to extend
#   UNIT_KEYWORDS (data-driven tuning). Default OFF.
#
# OTP delivery: WhatsApp OTP requires an APPROVED Meta template named
# "otp_verification" (language "ar"), body params {{1}}=code, {{2}}=expiry-minutes.
# Without it, OTP falls back to a plain text message (only deliverable inside
# Meta's 24h service window). See docs/whatsapp/SETUP_AND_OTP.md.
#
# OTP_HASH_SECRET (W726): server-side pepper used to HMAC-SHA256 every OTP
# before it is stored. The raw code is NEVER persisted. REQUIRED in production
# (falls back to JWT_SECRET/SESSION_SECRET if unset; dev uses a static pepper).
# OTP_HASH_SECRET=<random 32+ chars>
#
# LEGACY ALIASES (deprecated — consolidated W725, do NOT use in new envs):
#   WHATSAPP_ACCESS_TOKEN    → WHATSAPP_API_TOKEN
#   WHATSAPP_PHONE_NUMBER_ID → WHATSAPP_PHONE_ID
#   WHATSAPP_PROVIDER        → removed (Meta Cloud API is the only provider)

# ─── HR Webhooks (W1514) ─────────────────────────────────────
# Default OFF. When enabled, HR events (anomalies, change requests, etc.) can
# be POSTed to operator-supplied URLs signed with HMAC-SHA256.
# ENABLE_HR_WEBHOOKS=false
# HR_WEBHOOK_ALLOWED_DOMAINS=siem.example.com,slack-bridge.example.com  # comma-separated; empty = allow any domain after SSRF check
# HR_WEBHOOK_ALLOW_HTTP=false   # set true only in dev/test; production enforces HTTPS

# ─── Dormant event / alert capabilities ──────────────────────
# All default OFF. Enable individually after reviewing prerequisites.
# ENABLE_MODEL_EVENT_BRIDGE=false     # W974: publish Mongoose post-save events to integrationBus
# ALERTS_ENGINE_ENABLED=false         # W1244: smart alerts scheduler + Alert docs
# ALERTS_EMAIL_ENABLED=false          # W1244: email channel for alert engine (separate gate)
# ALERTS_ENGINE_INTERVAL_MS=300000    # default 5 minutes
# ENABLE_CARE_PLAN_WORKERS=false      # W973: overdue-review + family-retry workers
# ENABLE_RETENTION_SWEEP=false        # W983: beneficiary retention assessment sweep
# RETENTION_SWEEP_BRANCH_IDS=         # comma-separated branch IDs
# RETENTION_SWEEP_LIMIT=100
# ENABLE_SPEECH_RETENTION_CRON=false  # W284c: speech recording S3 retention (needs AWS_REGION + SPEECH_S3_BUCKET)

# ─── Azure OpenAI (used by WhatsApp AI service) ──────────────
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_KEY=...
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ─── Go-Live: Backups & Disaster Recovery ────────────────────
# BACKUP_ENCRYPTION_KEY=<64 hex chars>    # generate: node backend/scripts/backup-keygen.js
# ENABLE_AUTO_BACKUP=true                  # enables in-process nightly backup scheduler
# DB_BACKUP_KEEP_DAYS=30

# ─── Go-Live: Ops Alerting ────────────────────────────────────
# OPS_ALERT_EMAIL=oncall@example.org
# OPS_ALERT_PHONE=+966500000001            # WhatsApp/SMS fallback

# ─── Go-Live: Scheduler Feature Flags ───────────────────────
# NPHIES_RECON_ENABLED=true               # default on; set false to disable claim reconciliation sweeper
# ZATCA_SLA_SWEEPER_ENABLED=true          # enables ZATCA invoice SLA monitoring sweeper

# ─── Universal Codes (Barcode/QR) ────────────────────────────
# Optional 2-3-letter org prefix in generated codes (default `RH` for Al-Awael).
# Format: `<PREFIX>-<3-LETTER-TYPE>-<6CHARS>` e.g. `RH-BNF-A1B2C3`.
# UNIVERSAL_CODE_PREFIX=RH
# ─── CCTV / Camera Monitoring ──────────────────────────────
# Number of parallel probe workers for health checks (default 16).
# CCTV_PROBE_CONCURRENCY=16
# Set to 1 to bypass the event queue (tests / CI only).
# CCTV_QUEUE_DISABLE=0

# ─── Document Management & File Storage ───────────────────────
# Default provider for uploaded files: 'local' or 's3'.
# STORAGE_PROVIDER=local
#
# Absolute root path for local file storage (defaults to ./uploads in project root).
# UPLOADS_ROOT=/home/alawael/app/uploads
#
# Optional ClamAV host for virus scanning. If unset, uploads are accepted with
# a warning logged.
# CLAMAV_HOST=localhost
#
# AWS S3 region (also accepts AWS_REGION). Required when STORAGE_PROVIDER=s3.
# AWS_S3_REGION=me-central-1

# ─── Feature Flags ─────────────────────────────────────────────
# W1437 database-timeout safety fixes.
# FEATURE_W1437=true
#
# Generic dry-run switch used by some migration/seed scripts.
# DRY_RUN=0

# ════════════════════════════════════════════════════════════
# Notifications: Push / SMS / Email / WhatsApp
# ════════════════════════════════════════════════════════════

# ─── Firebase Cloud Messaging (FCM) ──────────────────────────
# FCM_PROJECT_ID=your-project-id
# FCM_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Apple Push Notification Service (APNS) ──────────────────
# APNS_KEY_PATH=/path/to/AuthKey_XXXXXXXXXX.p8
# APNS_KEY_ID=XXXXXXXXXX
# APNS_TEAM_ID=YYYYYYYYYY
# APNS_BUNDLE_ID=com.alawael.erp
# APNS_PRODUCTION=true

# ─── SMS Batching & Throttling ───────────────────────────────
# SMS_BATCH_SIZE=100
# SMS_THROTTLE_MS=1000

# ─── Email Campaign Tracking ─────────────────────────────────
# API_URL=https://api.alawael-erp.com
