# Minimal runtime template (backend)
# Purpose: smallest safe set to boot under strict env validation in CI/production.
#
# Generation hints:
#   openssl rand -base64 64
#
# Usage:
#   1) Copy to .env (or your secret manager)
#   2) Replace all CHANGE_ME values
#   3) Run: npm run env:check

NODE_ENV=production
PORT=3001

# Required by strictOverrides in config/validateEnv.js
MONGODB_URI=mongodb://127.0.0.1:27017/alawael_erp
JWT_SECRET=CHANGE_ME_64B
JWT_REFRESH_SECRET=CHANGE_ME_64B
ENCRYPTION_KEY=CHANGE_ME_64B
SESSION_SECRET=CHANGE_ME_64B

# Optional but commonly set
JWT_EXPIRES_IN=24h
