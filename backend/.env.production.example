# ═══════════════════════════════════════════════════════════════════════════════
# Al-Awael ERP — Production Environment Configuration
# Copy to .env on the production server and fill in real values
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
SERVICE_NAME=alawael-erp
SERVICE_VERSION=1.0.0
HOSTNAME=alaweal.org

# ─── Database ────────────────────────────────────────────────────────────────
# Use authenticated URI with admin credentials
MONGODB_URI=mongodb://alawael_admin:<PASSWORD>@127.0.0.1:27017/alawael_erp?authSource=admin
USE_MOCK_DB=false
MONGODB_MAX_POOL_SIZE=50
SLOW_QUERY_MS=200

# ─── Authentication & JWT ────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<GENERATE-64-CHAR-HEX>
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=<GENERATE-64-CHAR-HEX>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
SESSION_SECRET=<GENERATE-64-CHAR-HEX>
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW=900000

# ─── Encryption ──────────────────────────────────────────────────────────────
ENCRYPTION_KEY=<GENERATE-64-CHAR-HEX>

# ─── CORS & Frontend ────────────────────────────────────────────────────────
CORS_ORIGINS=https://alaweal.org,https://www.alaweal.org
FRONTEND_URL=https://alaweal.org
ALLOWED_ORIGINS=https://alaweal.org,https://www.alaweal.org

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=<SET-IF-CONFIGURED>

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=/home/alawael/logs
LOG_MAX_SIZE=50m
LOG_MAX_FILES=7d
ENABLE_AUDIT_LOG=true

# ─── Security ────────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_ENABLED=true
HELMET_ENABLED=true
TRUST_PROXY=1

# ─── File Upload ─────────────────────────────────────────────────────────────
UPLOAD_DIR=/home/alawael/app/uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,jpg,png

# ─── Email / SMTP (optional — fill when ready) ──────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=<EMAIL>
# SMTP_PASSWORD=<APP-PASSWORD>
# SMTP_FROM=noreply@alaweal.org
# EMAIL_ENABLED=true

# ─── Monitoring (optional) ──────────────────────────────────────────────────
# SENTRY_DSN=<SENTRY-DSN-FROM-DASHBOARD>
# SENTRY_ENVIRONMENT=production
# ENABLE_METRICS=true

# ─── PM2 / Process ──────────────────────────────────────────────────────────
PM2_INSTANCES=2
PM2_MAX_MEMORY=1024M

# ═══════════════════════════════════════════════════════════════════════
#  Saudi gov integrations — production defaults
#
#  All 10 adapters default to mock. Set {PROVIDER}_MODE=live only after
#  running `npm run preflight` and confirming the required vars are
#  populated. See docs/sprints/GOV_INTEGRATIONS_GO_LIVE.md for the
#  per-provider checklist and backend/.env.example for the full list
#  of rate-limit + circuit-breaker tunables.
#
#  Build-time identity — injected by CI per docs/deploy/BUILD_INFO_WIRING.md
#  so /api/build-info reports a real commit SHA instead of "unknown".
# ═══════════════════════════════════════════════════════════════════════

# GIT_SHA=<set-by-CI>
# BUILD_TIME=<set-by-CI>

# Stay mock until contracts are signed:
GOSI_MODE=mock
SCFHS_MODE=mock
ABSHER_MODE=mock
QIWA_MODE=mock
NAFATH_MODE=mock
FATOORA_MODE=mock
MUQEEM_MODE=mock
NPHIES_MODE=mock
WASEL_MODE=mock
BALADY_MODE=mock

# PDPL audit retention — 730 days matches Saudi health-record rules:
PDPL_AUDIT_TTL_DAYS=730

# ═══════════════════════════════════════════════════════════════════════
#  Speech analysis — PDPL retention gate (W284c/W284d)
#
#  The speech-retention sweeper purges audio after the retention window
#  defined per SpeechSessionRecording. It needs BOTH:
#    1. @aws-sdk/client-s3 installed (npm install @aws-sdk/client-s3)
#    2. AWS_REGION set below
#  Without these, the sweeper falls back to log-only — audio is NOT
#  actually deleted, which is a PDPL violation.
#
#  Verify go/no-go: npm run check:speech-s3-ready
#  Exit code 0 = safe to set ENABLE_SPEECH_RETENTION_CRON=true.
# ═══════════════════════════════════════════════════════════════════════

# AWS_REGION=me-south-1
# AWS_ACCESS_KEY_ID=<from-IAM-user-with-speech-bucket-write>
# AWS_SECRET_ACCESS_KEY=<from-IAM-user>
# SPEECH_S3_BUCKET=alawael-speech
# ENABLE_SPEECH_RETENTION_CRON=false   # set true ONLY after check-script exits 0
# SPEECH_ANALYSIS_PROVIDER=mock         # mock | openai-whisper-api | azure-speech
