# ═══════════════════════════════════════════════════════════════
# Al-Awael ERP — Production Environment Template
# Copy this file to .env.production, fill in real values, and
# load it at runtime via your secret manager or:
#   docker compose --env-file backend/.env.production -f ... up -d
#
# ⚠️  NEVER commit .env.production to version control!
# See docs/runbooks/production-secrets-cutover-checklist-w1406.md
# ═══════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=3001

# ─── Strict-required secrets (must come from a managed secret store) ───
MONGODB_URI=mongodb://user:password@mongodb:27017/alawael_erp?authSource=admin
JWT_SECRET=GENERATE_WITH_openssl_rand_base64_64
JWT_REFRESH_SECRET=GENERATE_WITH_openssl_rand_base64_64
ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_base64_32
SESSION_SECRET=GENERATE_WITH_openssl_rand_base64_64

# ─── Redis ───
REDIS_PASSWORD=GENERATE_STRONG_PASSWORD
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://:GENERATE_STRONG_PASSWORD@redis:6379
REDIS_ENABLED=true
DISABLE_REDIS=false

# ─── CORS / Frontend ───
FRONTEND_URL=https://alaweal.org
CORS_ORIGINS=https://alaweal.org,https://app.alaweal.org

# ─── Admin bootstrap (disable after first use) ───
SETUP_SECRET_KEY=GENERATE_RANDOM_SECRET
ADMIN_EMAIL=admin@alaweal.org
ADMIN_PASSWORD=GENERATE_STRONG_PASSWORD
# ALLOW_ADMIN_INIT=false

# ─── Observability ───
LOG_LEVEL=warn
ENABLE_SWAGGER=false

# ─── File uploads ───
FILE_SIZE_LIMIT_MB=50

# ─── Gov adapters (default to mock until live contracts are signed) ───
GOSI_MODE=mock
SCFHS_MODE=mock
ABSHER_MODE=mock
QIWA_MODE=mock
NAFATH_MODE=mock
ZATCA_SIGNER_MODE=mock
FATOORA_MODE=mock
MUQEEM_MODE=mock
NPHIES_MODE=mock
WASEL_MODE=mock
BALADY_MODE=mock
