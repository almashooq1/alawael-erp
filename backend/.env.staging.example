# ═══════════════════════════════════════════════════════════════════════════════
# Al-Awael ERP — Staging Environment Configuration
# Copy to .env on the staging server and fill in real values.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=staging
PORT=5000
SERVICE_NAME=alawael-erp-staging
SERVICE_VERSION=1.0.0
# HOSTNAME=staging.alaweal.org

# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://alawael_staging:<PASSWORD>@127.0.0.1:27017/alawael_erp_staging?authSource=admin
USE_MOCK_DB=false
MONGODB_MAX_POOL_SIZE=20
SLOW_QUERY_MS=150

# ─── Authentication & JWT ────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<GENERATE-64-CHAR-HEX>
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=<GENERATE-64-CHAR-HEX>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
SESSION_SECRET=<GENERATE-64-CHAR-HEX>
MAX_LOGIN_ATTEMPTS=10
LOGIN_ATTEMPT_WINDOW=900000

# ─── Encryption ──────────────────────────────────────────────────────────────
ENCRYPTION_KEY=<GENERATE-64-CHAR-HEX>

# ─── CORS & Frontend ────────────────────────────────────────────────────────
CORS_ORIGINS=https://staging.alaweal.org
FRONTEND_URL=https://staging.alaweal.org
ALLOWED_ORIGINS=https://staging.alaweal.org

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=<SET-IF-CONFIGURED>

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_DIR=/home/alawael/logs
LOG_MAX_SIZE=50m
LOG_MAX_FILES=3d
ENABLE_AUDIT_LOG=true

# ─── Security ────────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
RATE_LIMIT_ENABLED=true
HELMET_ENABLED=true
TRUST_PROXY=1

# ─── File Upload ─────────────────────────────────────────────────────────────
UPLOAD_DIR=/home/alawael/app/uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,jpg,png

# ─── Monitoring (recommended for staging) ────────────────────────────────────
# SENTRY_DSN=<SENTRY-DSN-FROM-DASHBOARD>
SENTRY_ENVIRONMENT=staging
# ENABLE_METRICS=true
ENABLE_SWAGGER=true

# ─── Email / SMTP (optional) ────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=<EMAIL>
# SMTP_PASSWORD=<APP-PASSWORD>
# SMTP_FROM=noreply-staging@alaweal.org
# EMAIL_ENABLED=false

# ─── PM2 / Process ──────────────────────────────────────────────────────────
PM2_INSTANCES=1
PM2_MAX_MEMORY=512M
