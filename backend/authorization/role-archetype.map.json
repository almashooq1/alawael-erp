  "rules": {
    "resolution": "effective grants for a live role = (archetype grants from role-permissions.seed.json) scoped to map.scope; approve-permissions apply only when map.approver=true",
    "driftGuard": "every value in rbac.config.js ROLES MUST appear exactly once in map[].live; a new live role with no archetype fails CI",
    "doNotFlatten": "the 46 live roles are NOT collapsed to 9 — they retain specialty/seniority identity for UI, scheduling, and reporting; the archetype is an additive classification tag",
    "approverSeniority": "within one archetype, approver=true roles are the 'checker' end of maker-checker (e.g. hr_manager approves what hr_officer submits); the matrix's !=req SoD still applies"
  }
