    "HR_OFFICER",
    "FINANCE_OFFICER",
    "AUDITOR",
    "NON_MATRIX"
  ],
  "scopes": [
    "G",
    "regional",
    "B",
    "U",
    "S",
    "self",
    "none"
  ],
