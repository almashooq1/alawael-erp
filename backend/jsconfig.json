{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2022",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@utils/*": ["utils/*"],
      "@models/*": ["models/*"],
      "@services/*": ["services/*"],
      "@controllers/*": ["controllers/*"],
      "@config/*": ["config/*"]
    },
    "checkJs": false,
    "resolveJsonModule": true,
    "moduleResolution": "node"
  },
  "include": ["**/*.js"],
  "exclude": ["node_modules", "coverage", "dist", "logs"]
}
