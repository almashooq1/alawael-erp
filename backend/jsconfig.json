{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2022",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@utils/*": ["utils/*"],
      "@models/*": ["models/*"],
      "@services/*": ["services/*"],
      "@controllers/*": ["controllers/*"],
      "@config/*": ["config/*"],
      "@middleware/*": ["middleware/*"],
      "@errors/*": ["errors/*"],
      "@routes/*": ["routes/*"]
    },
    "checkJs": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "strict": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["**/*.js"],
  "exclude": [
    "node_modules",
    "**/node_modules",
    "coverage",
    "dist",
    "build",
    "logs",
    ".jest-cache",
    "_archived",
    "uploads",
    "tests",
    "__tests__",
    "**/__snapshots__"
  ]
}
