{
  "name": "alawael-erp-backend",
  "version": "1.0.0",
  "description": "Al-Awael ERP Backend — RESTful API with Express, MongoDB, Redis, and Socket.IO",
  "keywords": [
    "erp",
    "express",
    "mongodb",
    "rest-api",
    "socket.io",
    "enterprise"
  ],
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "start:prod": "NODE_ENV=production node server.js",
    "dev": "nodemon server.js",
    "smoke:basic": "node scripts/smoke-basic.js",
    "smoke:health": "node scripts/smoke-health.js",
    "test": "jest --testPathPattern=\"(auth\\.test\\.js|documents-routes\\.phase3\\.test\\.js|messaging-routes\\.phase2\\.test\\.js|finance-routes\\.phase2\\.test\\.js|notifications-routes\\.phase2\\.test\\.js|reporting-routes\\.phase2\\.test\\.js|payrollRoutes\\.test\\.js|users\\.test\\.js|integration-routes\\.comprehensive\\.test\\.js|maintenance\\.comprehensive\\.test\\.js|notification-system\\.test\\.js|analytics-routes\\.test\\.js|assets-routes\\.test\\.js|health-routes\\.test\\.js|disability-rehabilitation\\.test\\.js|schedules\\.test\\.js|reports\\.test\\.js|health-advanced\\.test\\.js|assets-advanced\\.test\\.js|disability-rehabilitation-advanced\\.test\\.js|analytics-advanced\\.test\\.js|schedules-advanced\\.test\\.js|reports-advanced\\.test\\.js|finance-advanced\\.test\\.js|therapy-sessions|employee-affairs|government-integration|therapist-portal|guardian-portal|whatsapp-system|appointments-sessions-enhanced|email-system|strategic-planning-api|complaints-api|facilities-api|organization-api|succession-planning-api|meetings-api|visitors-api|knowledge-center-api)\" --coverage",
    "test:core": "jest __tests__/auth.test.js __tests__/documents-routes.phase3.test.js --no-coverage --testPathPattern=\"auth|documents-routes\\.phase3\"",
    "test:core:verbose": "jest __tests__/auth.test.js __tests__/documents-routes.phase3.test.js --no-coverage --verbose --testPathPattern=\"auth|documents-routes\\.phase3\"",
    "test:core:watch": "jest __tests__/auth.test.js __tests__/documents-routes.phase3.test.js --watch --no-coverage --testPathPattern=\"auth|documents-routes\\.phase3\"",
    "test:phase2": "jest __tests__/auth.test.js __tests__/documents-routes.phase3.test.js __tests__/messaging-routes.phase2.test.js __tests__/finance-routes.phase2.test.js __tests__/notifications-routes.phase2.test.js __tests__/reporting-routes.phase2.test.js --no-coverage",
    "test:phase2:verbose": "jest __tests__/auth.test.js __tests__/documents-routes.phase3.test.js __tests__/messaging-routes.phase2.test.js __tests__/finance-routes.phase2.test.js __tests__/notifications-routes.phase2.test.js __tests__/reporting-routes.phase2.test.js --no-coverage --verbose",
    "test:phase2:watch": "jest __tests__/auth.test.js __tests__/documents-routes.phase3.test.js __tests__/messaging-routes.phase2.test.js __tests__/finance-routes.phase2.test.js __tests__/notifications-routes.phase2.test.js __tests__/reporting-routes.phase2.test.js --watch --no-coverage",
    "test:phase3": "jest --no-coverage",
    "test:guard:maintenance-mocks": "node scripts/testing/check-maintenance-mocks-centralized.js",
    "quality:backend": "npm run test:guard:maintenance-mocks && npm test -- --passWithNoTests --no-coverage",
    "quality:ci": "npm run test:guard:maintenance-mocks && npm test -- --passWithNoTests --no-coverage --ci --runInBand",
    "quality:push": "npm run test:guard:maintenance-mocks && npm run test:phase2 -- --ci --runInBand",
    "quality:quick": "npm run test:guard:maintenance-mocks && npm run test:phase3",
    "test:all": "jest --coverage",
    "test:all:verbose": "jest --coverage --verbose",
    "test:quick": "jest --passWithNoTests --no-coverage --bail 1",
    "test:ci": "node --max-old-space-size=6144 node_modules/.bin/jest --passWithNoTests --no-coverage --ci --runInBand --forceExit",
    "test:perf": "node --max-old-space-size=8192 node_modules/.bin/jest --testPathPattern=\"stress-load|performance-load|load\\.test|performance-tuning|advanced-performance|phase-22-performance\" --no-coverage --runInBand --forceExit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,json,md}\"",
    "quality:guard": "npm run lint",
    "quality:fast": "npm run quality:guard && npm test -- --passWithNoTests --no-coverage",
    "quality": "npm run quality:ci",
    "db:seed": "node seed/disability-rehabilitation-seed.js && node seed/payroll-seed-data.js",
    "migrate:status": "node infrastructure/migrationRunner.js status",
    "migrate:up": "node infrastructure/migrationRunner.js up",
    "migrate:down": "node infrastructure/migrationRunner.js down",
    "migrate:create": "node infrastructure/migrationRunner.js create",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "aws-sdk": "^2.1693.0",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "csv-stringify": "^6.6.0",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "express-xss-sanitizer": "2.0.1",
    "firebase-admin": "^13.6.0",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.9.2",
    "joi": "^18.0.2",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.30.1",
    "mongoose": "^9.1.4",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cron": "4.2.1",
    "node-mailjet": "^6.0.11",
    "node-zklib": "1.3.0",
    "nodemailer": "^7.0.12",
    "paypal-rest-sdk": "^1.8.1",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.17.2",
    "pino": "^8.21.0",
    "pino-http": "^11.0.0",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.3.1",
    "razorpay": "^2.9.6",
    "socket.io": "^4.7.2",
    "speakeasy": "^2.0.0",
    "stripe": "^20.2.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.12.0",
    "uuid": "^8.3.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.2.0",
    "eslint": "^8.0.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.4.3",
    "nodemon": "^3.1.0",
    "prettier": "^3.0.0",
    "puppeteer": "^24.36.1",
    "supertest": "^6.3.4"
  }
}
