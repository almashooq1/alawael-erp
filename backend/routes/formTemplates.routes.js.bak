/* eslint-disable no-unused-vars */
/**
 * Form Templates Routes — مسارات النماذج الجاهزة
 * Ready-made form templates for beneficiaries, administration & HR
 *
 * @created 2026-03-13
 */

const express = require('express');
const router = express.Router();
const mongoose = require('mongoose');
const logger = require('../utils/logger');

// ─── Schema ────────────────────────────────────────────────────────────────

const FormFieldSchema = new mongoose.Schema(
  {
    name: { type: String, required: true },
    label: { type: String, required: true },
    labelEn: { type: String },
    type: {
      type: String,
      required: true,
      enum: [
        'text',
        'textarea',
        'number',
        'email',
        'tel',
        'date',
        'select',
        'radio',
        'checkbox',
        'file',
        'signature',
        'header',
        'divider',
      ],
    },
    placeholder: String,
    required: { type: Boolean, default: false },
    options: [{ label: String, value: String }],
    defaultValue: mongoose.Schema.Types.Mixed,
    validation: {
      min: Number,
      max: Number,
      minLength: Number,
      maxLength: Number,
      pattern: String,
    },
    gridSize: { type: Number, default: 12 }, // 1-12 for MUI grid
    order: { type: Number, default: 0 },
  },
  { _id: false }
);

const FormTemplateSchema = new mongoose.Schema(
  {
    templateId: { type: String, required: true, unique: true, index: true },
    name: { type: String, required: true },
    nameEn: { type: String },
    description: { type: String },
    category: {
      type: String,
      required: true,
      enum: ['beneficiary', 'hr', 'administration', 'finance', 'general'],
      index: true,
    },
    icon: { type: String, default: '📄' },
    color: { type: String, default: '#1976d2' },
    fields: [FormFieldSchema],
    isActive: { type: Boolean, default: true },
    isBuiltIn: { type: Boolean, default: true },
    requiresApproval: { type: Boolean, default: true },
    approvalSteps: [
      {
        role: String,
        label: String,
        order: Number,
      },
    ],
    outputFormat: {
      type: String,
      enum: ['pdf', 'docx', 'html'],
      default: 'pdf',
    },
    usageCount: { type: Number, default: 0 },
    createdBy: { type: mongoose.Schema.Types.ObjectId, ref: 'User' },
    tenantId: String,
  },
  { timestamps: true }
);

const FormSubmissionSchema = new mongoose.Schema(
  {
    templateId: { type: String, required: true, index: true },
    templateName: { type: String },
    submittedBy: {
      userId: { type: mongoose.Schema.Types.ObjectId, ref: 'User' },
      name: String,
      email: String,
      department: String,
    },
    data: { type: mongoose.Schema.Types.Mixed, required: true },
    status: {
      type: String,
      enum: ['draft', 'submitted', 'under_review', 'approved', 'rejected', 'cancelled'],
      default: 'submitted',
      index: true,
    },
    approvals: [
      {
        role: String,
        approvedBy: { type: mongoose.Schema.Types.ObjectId, ref: 'User' },
        approverName: String,
        status: { type: String, enum: ['pending', 'approved', 'rejected'] },
        comment: String,
        date: { type: Date },
      },
    ],
    submissionNumber: { type: String, unique: true },
    notes: String,
    attachments: [
      {
        filename: String,
        path: String,
        size: Number,
        mimeType: String,
      },
    ],
    tenantId: String,
  },
  { timestamps: true }
);

// Auto-generate submission number
FormSubmissionSchema.pre('save', function (next) {
  if (!this.submissionNumber) {
    const year = new Date().getFullYear();
    const rand = Math.floor(10000 + Math.random() * 90000);
    this.submissionNumber = `SUB-${year}-${rand}`;
  }
  next();
});

let FormTemplate, FormSubmission;
try {
  FormTemplate = mongoose.model('FormTemplate');
} catch {
  FormTemplate = mongoose.model('FormTemplate', FormTemplateSchema);
}
try {
  FormSubmission = mongoose.model('FormSubmission');
} catch {
  FormSubmission = mongoose.model('FormSubmission', FormSubmissionSchema);
}

