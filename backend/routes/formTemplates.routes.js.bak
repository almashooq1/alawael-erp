// ─── Seed built-in templates ───────────────────────────────────────────────

async function seedBuiltInTemplates() {
  try {
    for (const tpl of BUILT_IN_TEMPLATES) {
      await FormTemplate.findOneAndUpdate(
        { templateId: tpl.templateId },
        { $setOnInsert: { ...tpl, isBuiltIn: true, isActive: true } },
        { upsert: true, new: true }
      );
    }
    logger.info(`[FormTemplates] Seeded ${BUILT_IN_TEMPLATES.length} built-in templates`);
  } catch (err) {
    logger.warn(`[FormTemplates] Seed skipped (DB may not be connected): ${err.message}`);
  }
}

// Seed on first load if DB is connected
if (mongoose.connection.readyState === 1) {
  seedBuiltInTemplates();
} else {
  mongoose.connection.once('connected', seedBuiltInTemplates);
}

// ─── Routes ────────────────────────────────────────────────────────────────

/**
 * GET /api/form-templates
 * List all templates, optionally filtered by category
 */
router.get('/', async (req, res) => {
  try {
    const { category, search, page = 1, limit = 50 } = req.query;
    const filter = { isActive: true };

    if (category && category !== 'all') filter.category = category;
    if (search) {
      filter.$or = [
        { name: { $regex: search, $options: 'i' } },
        { description: { $regex: search, $options: 'i' } },
        { nameEn: { $regex: search, $options: 'i' } },
      ];
    }

    const skip = (parseInt(page) - 1) * parseInt(limit);
    const [templates, total] = await Promise.all([
      FormTemplate.find(filter)
        .sort({ category: 1, name: 1 })
        .skip(skip)
        .limit(parseInt(limit))
        .lean(),
      FormTemplate.countDocuments(filter),
    ]);

    res.json({
      success: true,
      templates,
      pagination: { page: +page, limit: +limit, total, pages: Math.ceil(total / limit) },
    });
  } catch (error) {
    logger.error('Error fetching form templates:', error);
    // Fallback to built-in templates if DB is unavailable
    const { category } = req.query;
    let templates = BUILT_IN_TEMPLATES;
    if (category && category !== 'all') {
      templates = templates.filter(t => t.category === category);
    }
    res.json({
      success: true,
      templates,
      pagination: { page: 1, limit: 50, total: templates.length },
    });
  }
});

/**
 * GET /api/form-templates/categories
 * Get template categories with counts
 */
router.get('/categories', async (req, res) => {
  try {
    const categories = [
      { id: 'all', label: 'جميع النماذج', labelEn: 'All Forms', icon: '📋', color: '#455A64' },
      {
        id: 'beneficiary',
        label: 'شؤون المستفيدين',
        labelEn: 'Beneficiary Affairs',
        icon: '🧑‍🦽',
        color: '#1565C0',
      },
      {
        id: 'hr',
        label: 'شؤون الموظفين',
        labelEn: 'Human Resources',
        icon: '👥',
        color: '#D32F2F',
      },
      {
        id: 'administration',
        label: 'الشؤون الإدارية',
        labelEn: 'Administration',
        icon: '🏛️',
        color: '#6D4C41',
      },
      { id: 'finance', label: 'الشؤون المالية', labelEn: 'Finance', icon: '💰', color: '#2E7D32' },
      { id: 'general', label: 'عامة', labelEn: 'General', icon: '📁', color: '#757575' },
    ];

    // Get counts from DB
    try {
      const counts = await FormTemplate.aggregate([
        { $match: { isActive: true } },
        { $group: { _id: '$category', count: { $sum: 1 } } },
      ]);
      const countMap = {};
      let totalCount = 0;
      counts.forEach(c => {
        countMap[c._id] = c.count;
        totalCount += c.count;
      });
      categories.forEach(cat => {
        cat.count = cat.id === 'all' ? totalCount : countMap[cat.id] || 0;
      });
    } catch {
      // Fallback counts from built-in
      categories.forEach(cat => {
        cat.count =
          cat.id === 'all'
            ? BUILT_IN_TEMPLATES.length
            : BUILT_IN_TEMPLATES.filter(t => t.category === cat.id).length;
      });
    }

    res.json({ success: true, categories });
  } catch (error) {
    res.status(500).json({ success: false, message: 'خطأ في جلب التصنيفات' });
  }
});

/**
 * GET /api/form-templates/stats
 * Get submission statistics
 */
router.get('/stats', async (req, res) => {
  try {
    const [totalTemplates, totalSubmissions, pendingSubmissions, approvedSubmissions] =
      await Promise.all([
        FormTemplate.countDocuments({ isActive: true }).catch(() => BUILT_IN_TEMPLATES.length),
        FormSubmission.countDocuments().catch(() => 0),
        FormSubmission.countDocuments({ status: { $in: ['submitted', 'under_review'] } }).catch(
          () => 0
        ),
        FormSubmission.countDocuments({ status: 'approved' }).catch(() => 0),
      ]);

    // Recent submissions
    const recentSubmissions = await FormSubmission.find()
      .sort({ createdAt: -1 })
      .limit(10)
      .lean()
      .catch(() => []);

    res.json({
      success: true,
      stats: {
        totalTemplates,
        totalSubmissions,
        pendingSubmissions,
        approvedSubmissions,
        rejectedSubmissions: totalSubmissions - pendingSubmissions - approvedSubmissions,
      },
      recentSubmissions,
    });
  } catch (error) {
    res.json({
      success: true,
      stats: {
        totalTemplates: BUILT_IN_TEMPLATES.length,
        totalSubmissions: 0,
        pendingSubmissions: 0,
        approvedSubmissions: 0,
        rejectedSubmissions: 0,
      },
      recentSubmissions: [],
    });
  }
});

/**
 * GET /api/form-templates/:id
 * Get a single template by templateId or _id
 */
router.get('/:id', async (req, res) => {
  try {
    let template = await FormTemplate.findOne({
      $or: [
        { templateId: req.params.id },
        { _id: mongoose.isValidObjectId(req.params.id) ? req.params.id : undefined },
      ],
    }).lean();

    if (!template) {
      // Try built-in
      template = BUILT_IN_TEMPLATES.find(t => t.templateId === req.params.id);
    }

    if (!template) {
      return res.status(404).json({ success: false, message: 'النموذج غير موجود' });
    }

    // Increment usage count
    if (template._id) {
      FormTemplate.updateOne({ _id: template._id }, { $inc: { usageCount: 1 } }).catch(() => {});
    }

    res.json({ success: true, template });
  } catch (error) {
    // Try built-in fallback
    const template = BUILT_IN_TEMPLATES.find(t => t.templateId === req.params.id);
    if (template) return res.json({ success: true, template });
    res.status(404).json({ success: false, message: 'النموذج غير موجود' });
  }
});

/**
 * POST /api/form-templates
 * Create a new custom template (admin only)
 */
router.post('/', async (req, res) => {
  try {
    const {
      name,
      nameEn,
      description,
      category,
      icon,
      color,
      fields,
      requiresApproval,
      approvalSteps,
    } = req.body;
    if (!name || !category) {
      return res.status(400).json({ success: false, message: 'اسم النموذج والتصنيف مطلوبان' });
    }

    const templateId = `custom-${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 6)}`;
    const template = await FormTemplate.create({
      templateId,
      name,
      nameEn,
      description,
      category,
      icon: icon || '📄',
      color: color || '#1976d2',
      fields: fields || [],
      isBuiltIn: false,
      requiresApproval: requiresApproval ?? true,
      approvalSteps: approvalSteps || [],
      createdBy: req.user?.id,
      tenantId: req.tenantId,
    });

    res.status(201).json({ success: true, template, message: 'تم إنشاء النموذج بنجاح' });
  } catch (error) {
    logger.error('Error creating form template:', error);
    res.status(500).json({ success: false, message: 'خطأ في إنشاء النموذج' });
  }
});

/**
 * PUT /api/form-templates/:id
 * Update a template
 */
router.put('/:id', async (req, res) => {
  try {
    const template = await FormTemplate.findOneAndUpdate(
      {
        $or: [
          { templateId: req.params.id },
          { _id: mongoose.isValidObjectId(req.params.id) ? req.params.id : undefined },
        ],
      },
      { $set: { ...req.body, updatedAt: new Date() } },
      { new: true }
    );
    if (!template) return res.status(404).json({ success: false, message: 'النموذج غير موجود' });
    res.json({ success: true, template, message: 'تم تحديث النموذج بنجاح' });
  } catch (error) {
    res.status(500).json({ success: false, message: 'خطأ في تحديث النموذج' });
  }
});

/**
 * DELETE /api/form-templates/:id
 * Soft delete a template
 */
router.delete('/:id', async (req, res) => {
  try {
    const template = await FormTemplate.findOneAndUpdate(
      {
        $or: [
          { templateId: req.params.id },
          { _id: mongoose.isValidObjectId(req.params.id) ? req.params.id : undefined },
        ],
      },
      { $set: { isActive: false } },
      { new: true }
    );
    if (!template) return res.status(404).json({ success: false, message: 'النموذج غير موجود' });
    res.json({ success: true, message: 'تم حذف النموذج بنجاح' });
  } catch (error) {
    res.status(500).json({ success: false, message: 'خطأ في حذف النموذج' });
  }
});

// ─── Submissions ───────────────────────────────────────────────────────────

/**
 * POST /api/form-templates/:id/submit
 * Submit a filled form
 */
router.post('/:id/submit', async (req, res) => {
  try {
    const { data, notes } = req.body;

    // Find the template
    let template = await FormTemplate.findOne({
      $or: [
        { templateId: req.params.id },
        { _id: mongoose.isValidObjectId(req.params.id) ? req.params.id : undefined },
      ],
    })
      .lean()
      .catch(() => null);

    if (!template) {
      template = BUILT_IN_TEMPLATES.find(t => t.templateId === req.params.id);
    }

    if (!template) {
      return res.status(404).json({ success: false, message: 'النموذج غير موجود' });
    }

    // Build approval chain
    const approvals = (template.approvalSteps || []).map(step => ({
      role: step.role,
      status: 'pending',
    }));

    const submission = await FormSubmission.create({
      templateId: template.templateId,
      templateName: template.name,
      submittedBy: {
        userId: req.user?.id,
        name: req.user?.name || req.body.submitterName || 'مستخدم',
        email: req.user?.email || '',
        department: req.body.department || '',
      },
      data,
      notes,
      status: template.requiresApproval ? 'submitted' : 'approved',
      approvals,
      tenantId: req.tenantId,
    });

    // Increment template usage
    if (template._id) {
      FormTemplate.updateOne({ _id: template._id }, { $inc: { usageCount: 1 } }).catch(() => {});
    }

    res.status(201).json({
      success: true,
      submission: {
        id: submission._id,
        submissionNumber: submission.submissionNumber,
        status: submission.status,
        templateName: submission.templateName,
      },
      message:
        submission.status === 'approved'
          ? 'تم إرسال النموذج والموافقة عليه تلقائياً'
          : 'تم إرسال النموذج بنجاح وهو بانتظار المراجعة',
    });
  } catch (error) {
    logger.error('Error submitting form:', error);
    res.status(500).json({ success: false, message: 'خطأ في إرسال النموذج' });
  }
});

/**
 * GET /api/form-templates/submissions/my
 * Get current user submissions
 */
router.get('/submissions/my', async (req, res) => {
  try {
    const userId = req.user?.id;
    const { status, page = 1, limit = 20 } = req.query;
    const filter = {};
    if (userId) filter['submittedBy.userId'] = userId;
    if (status) filter.status = status;

    const skip = (parseInt(page) - 1) * parseInt(limit);
    const [submissions, total] = await Promise.all([
      FormSubmission.find(filter).sort({ createdAt: -1 }).skip(skip).limit(parseInt(limit)).lean(),
      FormSubmission.countDocuments(filter),
    ]);

    res.json({ success: true, submissions, pagination: { page: +page, limit: +limit, total } });
  } catch (error) {
    res.json({ success: true, submissions: [], pagination: { page: 1, limit: 20, total: 0 } });
  }
});

/**
 * GET /api/form-templates/submissions/pending
 * Get pending submissions for approval
 */
router.get('/submissions/pending', async (req, res) => {
  try {
    const submissions = await FormSubmission.find({
      status: { $in: ['submitted', 'under_review'] },
    })
      .sort({ createdAt: -1 })
      .limit(50)
      .lean();

    res.json({ success: true, submissions });
  } catch (error) {
    res.json({ success: true, submissions: [] });
  }
});

/**
 * PUT /api/form-templates/submissions/:submissionId/approve
 * Approve a submission
 */
router.put('/submissions/:submissionId/approve', async (req, res) => {
  try {
    const { comment } = req.body;
    const submission = await FormSubmission.findById(req.params.submissionId);
    if (!submission) return res.status(404).json({ success: false, message: 'الطلب غير موجود' });

    // Find first pending approval and approve it
    const pendingApproval = submission.approvals.find(a => a.status === 'pending');
    if (pendingApproval) {
      pendingApproval.status = 'approved';
      pendingApproval.approvedBy = req.user?.id;
      pendingApproval.approverName = req.user?.name || 'مسؤول';
      pendingApproval.comment = comment;
      pendingApproval.date = new Date();
    }

    // Check if all approvals are done
    const allApproved = submission.approvals.every(a => a.status === 'approved');
    if (allApproved) {
      submission.status = 'approved';
    } else {
      submission.status = 'under_review';
    }

    await submission.save();
    res.json({ success: true, submission, message: 'تم اعتماد الطلب بنجاح' });
  } catch (error) {
    res.status(500).json({ success: false, message: 'خطأ في اعتماد الطلب' });
  }
});

/**
 * PUT /api/form-templates/submissions/:submissionId/reject
 * Reject a submission
 */
router.put('/submissions/:submissionId/reject', async (req, res) => {
  try {
    const { comment } = req.body;
    const submission = await FormSubmission.findByIdAndUpdate(
      req.params.submissionId,
      {
        $set: {
          status: 'rejected',
          'approvals.$[pending].status': 'rejected',
          'approvals.$[pending].comment': comment || 'مرفوض',
          'approvals.$[pending].approvedBy': req.user?.id,
          'approvals.$[pending].approverName': req.user?.name || 'مسؤول',
          'approvals.$[pending].date': new Date(),
        },
      },
      { new: true, arrayFilters: [{ 'pending.status': 'pending' }] }
    );

    if (!submission) return res.status(404).json({ success: false, message: 'الطلب غير موجود' });
    res.json({ success: true, submission, message: 'تم رفض الطلب' });
  } catch (error) {
    res.status(500).json({ success: false, message: 'خطأ في رفض الطلب' });
  }
});

module.exports = router;
