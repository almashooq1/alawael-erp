{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": "./.tsbuildinfo"
  },
  "include": [
    "models/**/*",
    "services/**/*",
    "controllers/**/*",
    "middleware/**/*",
    "utils/**/*",
    "config/**/*",
    "routes/**/*",
    "domains/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "logs",
    "exports",
    "uploads",
    "tests",
    "__tests__",
    "scripts",
    "seed",
    "seeds",
    "database"
  ],
  "watchOptions": {
    "watchFile": "useFsEvents",
    "watchDirectory": "useFsEvents",
    "fallbackPolling": "dynamicPriority"
  }
}