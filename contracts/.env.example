# Hardhat deploy env — fill before running `npx hardhat run scripts/deploy.js`.
# Same values can be reused by the backend (BLOCKCHAIN_ETH_RPC_URL +
# BLOCKCHAIN_ETH_PRIVATE_KEY) but keep them separate by default — the backend
# typically uses a different signer than the deployer.

DEPLOY_RPC_URL=
DEPLOYER_PRIVATE_KEY=
INITIAL_OWNER=             # optional — defaults to the deployer address
