{
  "name": "alawael-certificate-registry",
  "version": "1.0.0",
  "private": true,
  "description": "Al-Awael blockchain certificate registry contract — deployed to Ethereum/Polygon, called by backend EthereumAdapter.",
  "scripts": {
    "compile": "hardhat compile",
    "deploy:amoy": "hardhat run scripts/deploy.js --network amoy",
    "deploy:ethereum": "hardhat run scripts/deploy.js --network ethereum",
    "deploy:polygon": "hardhat run scripts/deploy.js --network polygon",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "test": "hardhat test"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "dotenv": "^16.4.0",
    "hardhat": "^2.22.0"
  }
}
