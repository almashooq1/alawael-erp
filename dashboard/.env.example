# Backend Configuration
NODE_ENV=production
PORT=3001
LOG_LEVEL=info
LOG_TO_FILE=true
CACHE_ENABLED=true
CACHE_TTL=3600

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost,http://frontend,http://0.0.0.0:80

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=alawael
DB_USER=alawael
DB_PASSWORD=alawael_secure_password

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Slack Integration (Optional)
SLACK_WEBHOOK_URL=

# Grafana Configuration
GF_ADMIN_PASSWORD=admin

# pgAdmin Configuration
PGADMIN_PASSWORD=admin

# API Key for Admin Endpoints
API_KEY=test-key-change-in-production

# React Frontend Configuration
REACT_APP_API_URL=http://localhost:3001
REACT_APP_WS_URL=ws://localhost:3001
