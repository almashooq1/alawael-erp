# ========================================
# ALAWAEL Quality Dashboard - Environment Variables
# Version 2.0.0 - Enhanced Edition
# ========================================

# Server Configuration
PORT=3001
NODE_ENV=development

# Database
DB_PATH=./data/quality.db

# Quality CLI Path (adjust to your workspace)
QUALITY_CLI_PATH=../../quality

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000

# API Configuration
API_RATE_LIMIT=100

# Security Configuration
# ========================================
# Generate a strong API key for admin operations
# Example: openssl rand -hex 32
API_KEY=your-secret-api-key-change-this-in-production

# CORS - Allowed Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3002,http://localhost:3000

# Logging Configuration
# ========================================
# Log levels: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# Enable file logging (logs stored in ./logs/)
LOG_TO_FILE=true

# Maximum log file size before rotation (MB)
LOG_MAX_SIZE=10

# Caching Configuration
# ========================================
# Enable response caching
CACHE_ENABLED=true

# Default cache TTL in seconds (5 minutes)
CACHE_DEFAULT_TTL=300

# Maximum cache size (number of keys)
CACHE_MAX_KEYS=1000

# Cache check period in seconds (delete expired keys)
CACHE_CHECK_PERIOD=60

# Rate Limiting Configuration
# ========================================
# Enable rate limiting
RATE_LIMIT_ENABLED=true

# Time window for rate limiting (milliseconds)
# Default: 15 minutes
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=100

# Strict rate limit for sensitive endpoints
STRICT_RATE_LIMIT_WINDOW_MS=60000
STRICT_RATE_LIMIT_MAX_REQUESTS=10

# Health Monitoring Configuration
# ========================================
# Memory usage warning threshold (percentage)
HEALTH_MEMORY_WARNING=85

# Memory usage critical threshold (percentage)
HEALTH_MEMORY_CRITICAL=95

# CPU load warning threshold (percentage)
HEALTH_CPU_WARNING=70

# CPU load critical threshold (percentage)
HEALTH_CPU_CRITICAL=90

# Error rate warning threshold (percentage)
HEALTH_ERROR_RATE_WARNING=5

# Error rate critical threshold (percentage)
HEALTH_ERROR_RATE_CRITICAL=10

# Health check history size (number of checks to store)
HEALTH_HISTORY_SIZE=100

# Performance Optimization Configuration
# ========================================
# Function execution slow threshold (ms)
PERF_SLOW_FUNCTION_THRESHOLD=100

# API endpoint slow threshold (ms)
PERF_SLOW_API_THRESHOLD=500

# Database query slow threshold (ms)
PERF_SLOW_QUERY_THRESHOLD=200

# Maximum performance history size
PERF_MAX_HISTORY=1000

# Slack Integration (if enabled)
# ========================================
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#quality-alerts
SLACK_USERNAME=ALAWAEL Quality Dashboard

# Email Notifications (if enabled)
# ========================================
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# ========================================
# Production Deployment Notes
# ========================================
#
# 1. Set NODE_ENV=production
# 2. Generate a strong API_KEY
# 3. Configure allowed origins in ALLOWED_ORIGINS
# 4. Set LOG_LEVEL=ERROR or WARN
# 5. Enable CACHE_ENABLED=true for better performance
# 6. Adjust rate limits based on your traffic
# 7. Configure health monitoring thresholds
# 8. Set up SSL/TLS certificates (use reverse proxy like nginx)
# 9. Configure backup strategy for database
# 10. Set up monitoring dashboards (Grafana)
#
# ========================================

