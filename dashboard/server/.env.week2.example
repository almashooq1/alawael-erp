# =============================================================================
# Phase 13 Week 2: Database & Redis Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Primary Database
# -----------------------------------------------------------------------------
DB_PRIMARY_HOST=localhost
DB_PRIMARY_PORT=5432
DB_PRIMARY_DATABASE=alawael_erp
DB_PRIMARY_USER=alawael_user
DB_PRIMARY_PASSWORD=your_secure_password_here

# Connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_CONNECTION_TIMEOUT=5000
DB_IDLE_TIMEOUT=30000
DB_STATEMENT_TIMEOUT=30000

# -----------------------------------------------------------------------------
# PostgreSQL Read Replicas (comma-separated)
# -----------------------------------------------------------------------------
# Format: host:port,host:port,host:port
DB_REPLICA_HOSTS=localhost:5433,localhost:5434
DB_REPLICA_USER=alawael_replica
DB_REPLICA_PASSWORD=your_replica_password_here

# Replica pool settings
DB_REPLICA_POOL_MIN=2
DB_REPLICA_POOL_MAX=10

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
# Mode: standalone | cluster | sentinel
REDIS_MODE=standalone

# Standalone mode (development)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Cluster mode (production)
# Format: host:port,host:port,host:port
REDIS_CLUSTER_NODES=localhost:7000,localhost:7001,localhost:7002

# Sentinel mode (high availability)
# Format: host:port,host:port,host:port
REDIS_SENTINEL_HOSTS=localhost:26379,localhost:26380,localhost:26381
REDIS_SENTINEL_NAME=mymaster

# Redis connection settings
REDIS_CONNECT_TIMEOUT=10000
REDIS_COMMAND_TIMEOUT=5000
REDIS_RETRY_STRATEGY=exponential
REDIS_MAX_RETRIES=10
REDIS_KEEP_ALIVE=30000

# -----------------------------------------------------------------------------
# Query Optimization Settings
# -----------------------------------------------------------------------------
# Enable query caching (true/false)
QUERY_CACHE_ENABLED=true

# Default cache TTL (seconds)
QUERY_CACHE_TTL=300

# Slow query threshold (milliseconds)
SLOW_QUERY_THRESHOLD=1000

# Very slow query threshold (milliseconds)
VERY_SLOW_QUERY_THRESHOLD=5000

# Enable query analysis (true/false)
QUERY_ANALYSIS_ENABLED=true

# Cache key prefix
CACHE_KEY_PREFIX=alawael:

# -----------------------------------------------------------------------------
# Performance Monitoring
# -----------------------------------------------------------------------------
# Enable performance metrics collection
METRICS_ENABLED=true

# Metrics collection interval (milliseconds)
METRICS_INTERVAL=60000

# Enable health checks
HEALTH_CHECK_ENABLED=true

# Health check interval (milliseconds)
HEALTH_CHECK_INTERVAL=30000

# -----------------------------------------------------------------------------
# Database Migration Settings
# -----------------------------------------------------------------------------
DB_MIGRATION_TABLE=schema_migrations
DB_MIGRATION_LOCK_TABLE=schema_migrations_lock
DB_AUTO_MIGRATE=false

# -----------------------------------------------------------------------------
# Batch Operation Settings
# -----------------------------------------------------------------------------
# Batch insert chunk size
BATCH_INSERT_CHUNK_SIZE=1000

# Batch operation timeout (milliseconds)
BATCH_OPERATION_TIMEOUT=60000

# -----------------------------------------------------------------------------
# Connection Retry Settings
# -----------------------------------------------------------------------------
DB_MAX_RETRIES=5
DB_RETRY_DELAY=1000
REDIS_MAX_RETRIES=10
REDIS_RETRY_DELAY=100

# -----------------------------------------------------------------------------
# Production Configuration Example
# -----------------------------------------------------------------------------
# For production, use these settings:
#
# REDIS_MODE=cluster
# REDIS_CLUSTER_NODES=redis-1.prod:6379,redis-2.prod:6379,redis-3.prod:6379
# DB_REPLICA_HOSTS=db-replica-1.prod:5432,db-replica-2.prod:5432
# DB_POOL_MAX=50
# DB_REPLICA_POOL_MAX=30
# QUERY_CACHE_TTL=600
# SLOW_QUERY_THRESHOLD=500
#
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Staging Configuration Example
# -----------------------------------------------------------------------------
# For staging, use these settings:
#
# REDIS_MODE=sentinel
# REDIS_SENTINEL_HOSTS=sentinel-1.staging:26379,sentinel-2.staging:26379
# DB_REPLICA_HOSTS=db-replica.staging:5432
# DB_POOL_MAX=30
# DB_REPLICA_POOL_MAX=20
# QUERY_CACHE_TTL=300
#
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Development Configuration (default)
# -----------------------------------------------------------------------------
# Development uses standalone Redis and single database
# No replicas needed, simpler setup
# -----------------------------------------------------------------------------
