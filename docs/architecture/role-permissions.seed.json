    "1": { "label": "normal", "reauthSeconds": null },
    "2": { "label": "sensitive", "reauthSeconds": 900 },
    "3": { "label": "critical", "reauthSeconds": 300 }
  },
  "predicates": {
    "G": "all branches",
    "B": "actor.branch",
    "U": "actor.unit",
    "S": "actor.caseload",
    "SELF": "actor's own record"
  },
