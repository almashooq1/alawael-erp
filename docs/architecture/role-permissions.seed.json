  "version": "1.0.0",
  "roles": [
    { "code": "HQA", "name": "HQ_ADMIN", "scopeLevel": "global", "kind": "technical" },
    { "code": "EXD", "name": "EXECUTIVE_DIRECTOR", "scopeLevel": "global", "kind": "business" },
    { "code": "BRM", "name": "BRANCH_MANAGER", "scopeLevel": "branch" },
    { "code": "UNS", "name": "UNIT_SUPERVISOR", "scopeLevel": "branch", "unitBound": true },
    { "code": "THR", "name": "THERAPIST", "scopeLevel": "service" },
    { "code": "REC", "name": "RECEPTIONIST", "scopeLevel": "branch" },
    { "code": "HRO", "name": "HR_OFFICER", "scopeLevel": "branch", "hqVariantGlobal": true },
    { "code": "FIN", "name": "FINANCE_OFFICER", "scopeLevel": "branch", "hqVariantGlobal": true },
    { "code": "AUD", "name": "AUDITOR", "scopeLevel": "global", "readOnly": true }
  ],
