    { "id": "S3", "rule": "hr:leave:create(self) XOR hr:leave:approve(self)", "severity": "block" },
    { "id": "S4", "rule": "hr:payroll:process XOR hr:payroll:approve (same run)", "severity": "block" },
    { "id": "S5", "rule": "AUDITOR XOR any create/update/delete/approve", "severity": "block" },
    { "id": "S6", "rule": "user:role_grant:assign XOR being the grantee", "severity": "block" },
    { "id": "S7", "rule": "clinical:approve XOR being the author", "severity": "warn->block" },
    { "id": "S8", "rule": "approval:request:create XOR approval:decision:approve (same request)", "severity": "block" }
  ],
  "approvalChains": [
    { "type": "clinical_signoff", "ladder": ["THR:submit", "UNS:approve", "BRM:dispute"] },
    { "type": "leave", "ladder": ["employee:create", "UNS:<=3d", "BRM:<=14d", "EXD:>14d"] },
    { "type": "billing", "ladder": ["FIN:submit", "BRM:<=limit", "EXD:>limit"] },
    { "type": "payroll", "ladder": ["HRO:process", "BRM|EXD:approve(!=processor)"] },
    { "type": "branch_role_grant", "ladder": ["BRM:request", "HQA:approve"] },
    { "type": "cross_branch_or_policy", "ladder": ["requester", "HQA+EXD:dual"] }
  ],
  "hqOnly": [
    "branch:org:create",
    "branch:org:delete",
    "user:account:create",
    "user:account:disable",
    "user:role_grant:assign(cross-branch)",
    "rbac:policy:manage",
    "report:*:export(consolidated-cross-branch)",
    "audit:log:export(global)"
  ],
  "delegation": {
    "subsetOnly": true,
    "alwaysTimeBoxed": true,
    "neverIncludes": ["user:role_grant:assign", "user:role_grant:revoke", "rbac:policy:manage"],
    "audited": "both delegator and actor identities recorded"
  },
  "breakGlass": {
    "tier": 3,
    "appliesTo": ["beneficiary:clinical:read", "assessment:record:read", "session:note:read"],
    "eligibleRoles": ["EXD"],
    "excludedRoles": ["HQA"],
    "autoExpireMinutes": 15,
    "requiresJustification": true,
    "postHocReview": true
  },
  "governance": {
    "changeProcess": "rbac:policy:manage change-request (maker-checker)",
    "driftGuard": "permissions.registry MUST equal this seed; CI fails on divergence",
    "reviewCadence": "quarterly re-attestation; non-default grants expire if not re-justified",
    "leastPrivilegeDefault": ["dashboard:view:read"]
  }
}
