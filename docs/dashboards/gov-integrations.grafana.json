{
  "__comment": "Grafana dashboard for the Saudi gov-adapter subsystem. Import via Grafana UI → Dashboards → Import → paste this JSON. Expects Prometheus datasource scraping /api/health/metrics/integrations. Tested against Grafana 10.x.",
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["alawael", "gov-integrations", "saudi"],
  "title": "Al-Awael — Gov Integrations Ops",
  "uid": "alawael-gov-integrations",
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "provider",
        "label": "Provider",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(gov_adapter_rate_limit_capacity, provider)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Circuits OPEN right now",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "refId": "A", "expr": "sum(gov_adapter_circuit_open)", "legendFormat": "open" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "graphMode": "none", "textMode": "value_and_name" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Providers configured",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(gov_adapter_configured) / count(gov_adapter_configured) * 100",
          "legendFormat": "configured %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg rate-limit utilization",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(gov_adapter_rate_limit_utilization_percent)",
          "legendFormat": "avg util"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Live-mode providers",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "count(gov_adapter_mode == 1)",
          "legendFormat": "live"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Rate-limit utilization (%) — per provider",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "gov_adapter_rate_limit_utilization_percent{provider=~\"$provider\"}",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Tokens available",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "gov_adapter_rate_limit_available{provider=~\"$provider\"}",
          "legendFormat": "{{provider}} available"
        },
        {
          "refId": "B",
          "expr": "gov_adapter_rate_limit_capacity{provider=~\"$provider\"}",
          "legendFormat": "{{provider}} capacity"
        }
      ]
    },
    {
      "id": 7,
      "type": "state-timeline",
      "title": "Circuit breakers",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "gov_adapter_circuit_open",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "closed", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "OPEN", "color": "red" } } }
          ]
        }
      }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Circuit failures (current rolling window)",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "gov_adapter_circuit_failures",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Active actors per provider (last 60s)",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "gov_adapter_rate_limit_active_actors{provider=~\"$provider\"}",
          "legendFormat": "{{provider}}"
        }
      ],
      "options": { "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Request rate (req/s) — per provider, per status",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (provider, status) (rate(gov_adapter_calls_total{provider=~\"$provider\"}[5m]))",
          "legendFormat": "{{provider}} · {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Success rate (5m) — per provider",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (provider) (rate(gov_adapter_calls_total{status=\"success\",provider=~\"$provider\"}[5m])) / sum by (provider) (rate(gov_adapter_calls_total{provider=~\"$provider\"}[5m])) * 100",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8 }
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "p50 / p95 / p99 latency (ms) — per provider",
      "gridPos": { "x": 0, "y": 36, "w": 24, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le, provider) (rate(gov_adapter_call_latency_ms_bucket{provider=~\"$provider\"}[5m])))",
          "legendFormat": "{{provider}} p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(gov_adapter_call_latency_ms_bucket{provider=~\"$provider\"}[5m])))",
          "legendFormat": "{{provider}} p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le, provider) (rate(gov_adapter_call_latency_ms_bucket{provider=~\"$provider\"}[5m])))",
          "legendFormat": "{{provider}} p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "drawStyle": "line" } }
      }
    }
  ]
}
