# Frontend Configuration
# تكوين الواجهة الأمامية

# API Configuration
REACT_APP_API_URL=http://localhost:3001/api
# Versioned API URL — defaults to REACT_APP_API_URL when unset.
REACT_APP_API_V1_URL=
REACT_APP_API_TIMEOUT=30000

# WebSocket / real-time channels (notifications, dashboard updates).
# Leave blank to fall back to inferred URL based on REACT_APP_API_URL.
REACT_APP_WS_URL=
REACT_APP_SOCKET_URL=

# App Configuration
# Set by the deploy workflow at build time — used by Sentry init + version chip.
REACT_APP_VERSION=1.0.0
REACT_APP_ENVIRONMENT=development

# Error Tracking — Sentry (Optional but recommended for production)
# Get your DSN from https://sentry.io → Settings → Client Keys
REACT_APP_SENTRY_DSN=
