  "private": true,
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "lint": "eslint src/ --max-warnings=0",
    "lint:fix": "eslint src/ --ext .js,.jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,json,css}\"",
    "quality:guard": "jest --passWithNoTests",
    "quality:fast": "jest --passWithNoTests --coverage",
    "quality:ci": "jest --passWithNoTests --coverage --watchAll=false",
    "quality": "npm run quality:ci",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "analyze": "npx source-map-explorer 'build/static/js/*.js'"
  },
