{
  "name": "alawael-erp-frontend",
  "version": "3.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "node scripts/verify-build.cjs",
    "test": "vitest run --pool=forks src/utils src/services src/hooks",
    "test:watch": "vitest",
    "test:components": "vitest run --pool=forks src/pages/Admin",
    "test:full": "vitest run",
    "preview": "vite preview",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 1000",
    "mobile:sync": "npx cap sync",
    "mobile:android": "npx cap open android",
    "mobile:ios": "npx cap open ios",
    "mobile:build:android": "npm run build && npx cap sync android && cd android && ./gradlew assembleRelease",
    "mobile:build:ios": "npm run build && npx cap sync ios && cd ios/App && xcodebuild -workspace App.xcworkspace -scheme App -configuration Release archive -archivePath build/App.xcarchive",
    "mobile:assets": "npx capacitor-assets generate"
  },
  "dependencies": {
    "@capacitor-community/barcode-scanner": "^4.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/network": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/screen-orientation": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/toast": "^6.0.0",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@fontsource/cairo": "^5.2.7",
    "@hookform/resolvers": "^3.3.0",
    "@mui/icons-material": "^6.0.0",
    "@mui/material": "^6.0.0",
    "@sentry/react": "^10.62.0",
    "@tanstack/react-query": "^5.8.0",
    "@tanstack/react-query-devtools": "^5.101.2",
    "axios": "^1.6.0",
    "axios-retry": "^4.0.0",
    "capacitor-plugin-safe-area": "^3.0.0",
    "chart.js": "^4.4.0",
    "date-fns": "^2.30.0",
    "dompurify": "^3.4.11",
    "exceljs": "^4.4.0",
    "framer-motion": "^10.16.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.294.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.48.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.0",
    "socket.io-client": "^4.8.3",
    "stylis": "^4.4.0",
    "stylis-plugin-rtl": "^2.1.1",
    "tailwindcss": "^3.3.0",
    "web-vitals": "^4.2.4",
    "zod": "^3.22.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/ios": "^6.0.0",
    "@eslint/js": "^8.57.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.53.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.0",
    "typescript": "^5.2.0",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^0.17.0",
    "vitest": "^4.1.9"
  }
}
