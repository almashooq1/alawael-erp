{
  "name": "rehabilitation-frontend",
  "version": "1.0.0",
  "description": "واجهة مستخدم نظام مراكز الأوائل للرعاية النهارية",
  "private": true,
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint src/ --ext .js,.jsx",
    "lint:fix": "eslint src/ --ext .js,.jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,json,css}\"",
    "quality:guard": "react-scripts test --passWithNoTests",
    "quality:fast": "npm run quality:guard -- --coverage --passWithNoTests",
    "quality:ci": "npm run quality:guard -- --coverage --passWithNoTests --watchAll=false",
    "quality": "npm run quality:ci",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "analyze": "npx source-map-explorer 'build/static/js/*.js'"
  },
  "dependencies": {
    "@emotion/cache": "^11.11.0",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@fontsource/cairo": "^5.0.0",
    "@mui/icons-material": "^5.15.0",
    "@mui/material": "^5.15.0",
    "axios": "^1.13.6",
    "chart.js": "^4.4.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "formik": "^2.4.9",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "i18next": "^25.10.5",
    "jspdf": "^4.2.1",
    "notistack": "^3.0.2",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.6.2",
    "react-router-dom": "^6.20.0",
    "react-scripts": "5.0.1",
    "recharts": "^3.7.0",
    "socket.io-client": "^4.8.3",
    "stylis": "^4.3.6",
    "stylis-plugin-rtl": "^2.1.1",
    "web-vitals": "^5.1.0",
    "exceljs": "^4.4.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "axe-core": "^4.11.1",
    "cypress": "^15.12.0",
    "cypress-axe": "^1.7.0",
    "eslint-plugin-unused-imports": "^4.4.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "proxy": "http://localhost:3001",
  "jest": {
    "coverageThreshold": {
      "global": {
        "statements": 40,
        "branches": 25,
        "functions": 30,
        "lines": 40
      }
    }
  }
}
