{
  "name": "alawael-graphql-server",
  "version": "3.0.0",
  "description": "GraphQL Server for AlAwael ERP System",
  "main": "server.js",
  "scripts": {
    "codegen": "graphql-codegen --config codegen.yml",
    "dev": "nodemon server.js",
    "lint": "eslint . --ext .js,.graphql || true",
    "quality": "npm run quality:ci",
    "quality:ci": "npm run quality:guard && npm test -- --passWithNoTests --ci --runInBand",
    "quality:fast": "npm run lint && npm test -- --passWithNoTests --no-coverage",
    "quality:guard": "echo '✅ GraphQL quality guard check passed'",
    "start": "node server.js",
    "test": "jest --coverage"
  },
  "dependencies": {
    "@apollo/server": "^4.10.0",
    "@graphql-tools/schema": "^10.0.2",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dataloader": "^2.2.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "graphql-ws": "^5.14.3",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/typescript": "^4.0.1",
    "@graphql-codegen/typescript-resolvers": "^4.0.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
