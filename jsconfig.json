{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "checkJs": false,
    "maxNodeModuleJsDepth": 0
  },
  "include": ["*.js", "scripts/**/*.js", "ops/**/*.js"],
  "exclude": [
    "node_modules",
    "**/node_modules",
    "dist",
    "build",
    "coverage",
    "logs",
    "uploads",
    "certs",
    "_archived",
    "backend",
    "frontend",
    "mobile",
    "supply-chain-management",
    "services",
    "contracts",
    "docs",
    "nginx"
  ]
}
