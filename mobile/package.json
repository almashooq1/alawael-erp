{
  "name": "alawael-erp-mobile",
  "version": "1.0.0",
  "description": "AlAwael ERP Mobile Application - React Native with Expo",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "android": "expo start --android",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "eject": "expo eject",
    "ios": "expo start --ios",
    "lint": "eslint \"src/**/*.{ts,tsx}\" App.tsx --max-warnings=0",
    "quality": "npm run quality:ci",
    "quality:ci": "npm run quality:guard && npm test -- --coverage --passWithNoTests",
    "quality:fast": "npm run quality:guard && npm test -- --passWithNoTests",
    "quality:guard": "npm run type-check && npm run lint",
    "start": "expo start",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios",
    "test": "jest",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit",
    "web": "expo start --web"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.0",
    "@xmldom/xmldom": "^0.9.10",
    "brace-expansion": "^2.0.3",
    "fast-xml-parser": "^5.7.2",
    "follow-redirects": "^1.15.12",
    "http-proxy-agent": "^7.0.2",
    "jsdom": "^25.0.0",
    "minimatch": "^9.0.5",
    "node-forge": "^1.3.4",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.10",
    "semver": "^7.6.3",
    "send": "^0.19.0",
    "tar": "^7.5.11",
    "test-exclude": "^7.0.1",
    "uuid": "^14.0.0",
    "yaml": "^2.8.3"
  },
  "dependencies": {
    "@expo/vector-icons": "^13.0.0",
    "@react-native-async-storage/async-storage": "^1.21.0",
    "@react-navigation/bottom-tabs": "^6.5.8",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^6.9.13",
    "@reduxjs/toolkit": "^1.9.6",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "axios": "^1.16.1",
    "date-fns": "^2.30.0",
    "expo": "^49.0.0",
    "expo-device": "^5.4.0",
    "expo-font": "^11.4.0",
    "expo-notifications": "^0.20.0",
    "expo-secure-store": "^12.3.0",
    "expo-splash-screen": "^0.30.10",
    "expo-sqlite": "^11.3.3",
    "expo-status-bar": "^1.6.0",
    "lodash": "^4.17.21",
    "react": "^18.2.0",
    "react-native": "^0.72.0",
    "react-native-flash-message": "^0.4.1",
    "react-native-gesture-handler": "^2.14.0",
    "react-native-paper": "^5.15.2",
    "react-native-safe-area-context": "^4.7.1",
    "react-native-screens": "^3.25.0",
    "react-native-svg": "^13.12.0",
    "react-native-vector-icons": "^9.2.0",
    "react-redux": "^8.1.3",
    "redux": "^4.2.1"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@types/jest": "^29.5.4",
    "@types/lodash": "^4.14.199",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^8.59.3",
    "babel-jest": "^29.7.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "jest-expo": "^49.0.0",
    "prettier": "^3.8.3",
    "typescript": "^5.2.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
