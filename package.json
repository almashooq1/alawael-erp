{
  "name": "alawael-erp",
  "version": "1.0.0",
  "private": true,
  "description": "Al-Awael Day Care Centers — نظام مراكز الأوائل للرعاية النهارية",
  "homepage": "https://github.com/almashooq1/alawael-erp#readme",
  "bugs": {
    "url": "https://github.com/almashooq1/alawael-erp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/almashooq1/alawael-erp.git"
  },
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "attendance:digest": "cd backend && npm run attendance:digest",
    "attendance:digest:json": "cd backend && npm run attendance:digest:json",
    "build": "cd frontend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "check:deps": "cd backend && npm run check:deps",
    "check:services": "cd backend && npm run check:services",
    "claims:digest": "cd backend && npm run claims:digest",
    "claims:digest:json": "cd backend && npm run claims:digest:json",
    "clean": "rimraf node_modules backend/node_modules frontend/node_modules",
    "cleanup": "cd backend && npm run cleanup",
    "cleanup:run": "cd backend && npm run cleanup:run",
    "complaints:digest": "cd backend && npm run complaints:digest",
    "complaints:digest:json": "cd backend && npm run complaints:digest:json",
    "cpe:attention": "cd backend && npm run cpe:attention",
    "cpe:attention:json": "cd backend && npm run cpe:attention:json",
    "db:reset": "cd backend && npm run db:reset",
    "db:seed": "cd backend && npm run db:seed",
    "db:seed:rehab": "cd backend && npm run db:seed:rehab",
    "db:status": "cd backend && npm run db:status",
    "deploy:build": "cd frontend && npm run build && cd ../backend && npm ci --only=production",
    "predeploy:docker": "node scripts/prepare-deploy.js --docker",
    "deploy:docker": "docker compose -f docker-compose.professional.yml up -d --build",
    "deploy:docker:down": "docker compose -f docker-compose.professional.yml down",
    "deploy:hostinger": "node scripts/deploy-hostinger.js",
    "deploy:hostinger:check": "node scripts/deploy-hostinger.js --check-only",
    "dev": "cd backend && npm run dev",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run start:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "doc-expiry:digest": "cd backend && npm run doc-expiry:digest",
    "doc-expiry:digest:json": "cd backend && npm run doc-expiry:digest:json",
    "docker:build": "GIT_SHA=$(git rev-parse HEAD) BUILD_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ) docker compose build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:up": "docker compose up -d",
    "dsar:hash": "cd backend && npm run dsar:hash --silent --",
    "forecast:digest": "cd backend && npm run forecast:digest",
    "forecast:digest:json": "cd backend && npm run forecast:digest:json",
    "generate:secrets": "cd backend && npm run generate:secrets",
    "goal-progress:digest": "cd backend && npm run goal-progress:digest",
    "goal-progress:digest:json": "cd backend && npm run goal-progress:digest:json",
    "gov:status": "cd backend && npm run gov:status",
    "gov:status:json": "cd backend && npm run gov:status:json",
    "incidents:digest": "cd backend && npm run incidents:digest",
    "incidents:digest:json": "cd backend && npm run incidents:digest:json",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "lint": "cd backend && npm run lint",
    "lint:all": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "cd backend && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "logs": "cd backend && npm run logs:view",
    "logs:errors": "cd backend && npm run logs:errors",
    "outcomes:digest": "cd backend && npm run outcomes:digest",
    "outcomes:digest:json": "cd backend && npm run outcomes:digest:json",
    "predeploy": "node scripts/prepare-deploy.js",
    "preflight": "cd backend && npm run preflight",
    "preflight:prod": "cd backend && npm run preflight:prod",
    "prepare": "husky",
    "quality": "cd backend && npm run quality:ci",
    "quality:quick": "cd backend && npm run quality:quick",
    "referrals:digest": "cd backend && npm run referrals:digest",
    "referrals:digest:json": "cd backend && npm run referrals:digest:json",
    "retention:digest": "cd backend && npm run retention:digest",
    "retention:digest:json": "cd backend && npm run retention:digest:json",
    "revenue:digest": "cd backend && npm run revenue:digest",
    "revenue:digest:json": "cd backend && npm run revenue:digest:json",
    "routes": "cd backend && npm run routes:list",
    "saudization:digest": "cd backend && npm run saudization:digest",
    "saudization:digest:json": "cd backend && npm run saudization:digest:json",
    "seed:demo:dry": "cd backend && npm run seed:demo:dry",
    "seed:demo:reset": "cd backend && npm run seed:demo:reset",
    "setup": "cd backend && npm run setup",
    "setup:force": "cd backend && npm run setup -- --force",
    "ship-check": "npm run test:drift && npm run preflight && npm run test:ops-subsystems",
    "start": "cd backend && npm start",
    "start:backend": "cd backend && npm start",
    "start:frontend": "cd frontend && npm start",
    "start:prod": "cd backend && node server.js",
    "stats": "cd backend && npm run stats",
    "test": "cd backend && npm test",
    "test:backend": "cd backend && npm test",
    "test:drift": "cd backend && npm run test:drift",
    "test:frontend": "cd frontend && npm test -- --watchAll=false",
    "test:ops-subsystems": "cd backend && npm run test:ops-subsystems",
    "test:sprint": "cd backend && npm run test:sprint",
    "utilization:digest": "cd backend && npm run utilization:digest",
    "utilization:digest:json": "cd backend && npm run utilization:digest:json",
    "waitlist:digest": "cd backend && npm run waitlist:digest",
    "waitlist:digest:json": "cd backend && npm run waitlist:digest:json"
  },
  "lint-staged": {
    "backend/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "frontend/src/**/*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@inertiajs/vue3": "^3.0.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "csv-parse": "^6.2.1",
    "dompurify": "^3.3.3",
    "framer-motion": "^12.38.0",
    "i18next": "^25.10.5",
    "jspdf": "^4.2.1",
    "libsodium-wrappers": "^0.8.2",
    "react-i18next": "^16.6.2",
    "stripe": "^20.4.1",
    "twilio": "^5.13.0",
    "uuid": "^13.0.0",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "concurrently": "^8.2.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "mongodb-memory-server": "^11.0.1",
    "tailwindcss": "^4.2.2"
  },
  "optionalDependencies": {
    "winston": "^3.19.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
