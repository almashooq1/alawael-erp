{
  "name": "alawael-queue-worker",
  "version": "1.0.0",
  "description": "خدمة معالجة المهام الخلفية — Background Job Queue Worker (BullMQ)",
  "main": "worker.js",
  "scripts": {
    "dev": "nodemon worker.js",
    "lint": "eslint . --ext .js || true",
    "quality:ci": "npm run lint && npm test",
    "start": "node worker.js",
    "test": "jest --passWithNoTests --coverage"
  },
  "overrides": {
    "uuid": "$uuid"
  },
  "dependencies": {
    "bullmq": "^5.1.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "ioredis": "^5.3.2",
    "mongoose": "^8.1.0",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.19.0",
    "sharp": "^0.34.5",
    "uuid": "^11.1.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^10.3.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
