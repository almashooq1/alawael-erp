{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@supply-chain-backend/*": ["supply-chain-management/backend/*"],
      "@supply-chain-frontend/*": ["supply-chain-management/frontend/src/*"],
      "@/*": ["src/*"]
    }
  },
  "include": ["dashboard/server/**/*.ts", "dashboard/server/**/*.js"],
  "exclude": [
    "node_modules",
    "**/node_modules",
    "dist",
    "**/dist",
    "build",
    "**/build",
    "coverage",
    "**/coverage",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.map",
    "**/.next",
    "**/out",
    "**/.git",
    "**/tmp",
    "**/temp",
    "**/.terraform",
    "archive/**",
    "intelligent-agent/**",
    "whatsapp/**",
    "backend/**",
    "frontend/**",
    "dashboard/client/**",
    "graphql/**",
    "finance-module/**",
    "gateway/**",
    "mobile/**"
  ]
}
